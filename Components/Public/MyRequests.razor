@page "/public/my-requests"
@layout PublicLayout
@attribute [Authorize]

@inject RequestService RequestService
@inject AuthStateProvider AuthState
@inject NavigationManager NavManager

<PageTitle>Mes demandes - Créalab</PageTitle>

<div class="main-container theme-industrial">
    <header class="public-header public-header--with-action">
        <div>
            <h1>Mes Demandes</h1>
            <p>Suivez l'avancement de vos demandes d'impression et de découpe.</p>
        </div>
        <a href="/public/request" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Nouvelle demande
        </a>
    </header>

    <div class="requests-wrapper">
        @if (Requests.Count == 0)
        {
            <div class="empty-state">
                <i class="fa-solid fa-inbox fa-3x"></i>
                <h3>Aucune demande</h3>
                <p>Vous n'avez pas encore soumis de demande.</p>
                <a href="/public/request" class="btn-primary">
                    <i class="fa-solid fa-plus"></i> Créer une demande
                </a>
            </div>
        }
        else
        {
            <div class="requests-list">
                @foreach (var request in Requests)
                {
                    var statusCss = GetStatusCssClass(request.Status);

                    <div class="request-card" @onclick="() => GoToDetail(request.Id)">
                        <div class="request-card-header">
                            <span class="badge @statusCss">@request.Status.GetDisplayName()</span>
                            <span class="request-date">@request.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h4 class="request-title">@request.Title</h4>
                        <div class="request-meta">
                            <span class="meta-item">
                                <i class="fa-solid fa-cube"></i> @request.Type.GetDisplayName()
                            </span>
                            <span class="meta-item">
                                <i class="fa-solid fa-tag"></i> @request.Context.GetDisplayName()
                            </span>
                            <span class="meta-item">
                                <i class="fa-solid fa-paperclip"></i> @request.Fichiers.Count fichier(s)
                            </span>
                        </div>
                        @if (request.Fichiers.Any(f => f.ReviewStatus == FileReviewStatus.Refused || f.ReviewStatus == FileReviewStatus.NeedsModification))
                        {
                            <div class="request-alert">
                                <i class="fa-solid fa-triangle-exclamation"></i> Des fichiers nécessitent votre attention
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Requete> Requests = new();

    protected override async Task OnInitializedAsync()
    {
        var user = AuthState.CurrentUser;
        if (user != null)
        {
            Requests = await RequestService.GetRequestsForUserAsync(user.Id);
        }

        #if DEBUG
        if (Requests.Count == 0) LoadMockRequests();
        #endif
    }

    private void GoToDetail(int id) => NavManager.NavigateTo($"/public/my-requests/{id}");

    private static string GetStatusCssClass(RequestStatus s) => s switch
    {
        RequestStatus.Submitted => "badge-info",
        RequestStatus.UnderReview => "badge-warning",
        RequestStatus.Approved => "badge-success",
        RequestStatus.Rejected => "badge-danger",
        RequestStatus.InProgress => "badge-primary",
        RequestStatus.Completed => "badge-success",
        RequestStatus.Cancelled => "badge-secondary",
        _ => ""
    };

    #if DEBUG
    private void LoadMockRequests()
    {
        var mockUser = new Membre { Id = 16, FirstName = "Nathan", LastName = "Simon", Email = "nathan.simon@edu.devinci.fr", UserRoles = [new AppUserRole { RoleId = 2, Role = new Role { Id = 2, DisplayName = "Membre" } }] };

