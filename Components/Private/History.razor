@page "/private/history"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@inject PageHeaderService HeaderService
@inject PrintJobService PrintJobService
@inject PrinterService PrinterService

<PageTitle>Créalab - Historique</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="stats-summary">
        <div class="stat-box">
            <span class="stat-value">@PrintJobs.Count</span>
            <span class="stat-label">Impressions</span>
        </div>
        <div class="stat-box">
            <span class="stat-value">@TotalWeight kg</span>
            <span class="stat-label">Filament consommé</span>
        </div>
        <div class="stat-box">
            <span class="stat-value">@SuccessRate%</span>
            <span class="stat-label">Taux de succès</span>
        </div>
    </div>
</SectionContent>

<div class="main-container theme-industrial">

    <!-- Filtres -->
    <div class="filter-bar">
        <div class="filter-group">
            <select class="form-input" @bind="FilterPrinterId" @bind:after="LoadJobs">
                <option value="">Toutes les imprimantes</option>
                @foreach (var printer in Printers)
                {
                    <option value="@printer.Id">@printer.Name</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <select class="form-input" @bind="FilterStatus" @bind:after="LoadJobs">
                <option value="">Tous les statuts</option>
                @foreach (var status in Enum.GetValues<PrintStatus>())
                {
                    <option value="@status">@status.GetDisplayName()</option>
                }
            </select>
        </div>
    </div>

    @if (PrintJobs.Count == 0)
    {
        <div class="empty-state">
            <i class="fa-solid fa-clock-rotate-left"></i>
            <p>Aucune impression enregistrée.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <div class="table-scroll">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Statut</th>
                            <th>Fichier</th>
                            <th>Imprimante</th>
                            <th>Date</th>
                            <th>Durée</th>
                            <th>Conso.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in PrintJobs)
                        {
                            <tr class="job-row">
                                <td>
                                    <span class="status-badge @job.StatusCssClass">
                                        @if (job.Status == PrintStatus.Success)
                                        {
                                            <i class="fa-solid fa-check"></i>
                                        }
                                        else if (job.Status == PrintStatus.Failed)
                                        {
                                            <i class="fa-solid fa-triangle-exclamation"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-ban"></i>
                                        }
                                        @job.StatusLabel
                                    </span>
                                </td>
                                <td class="file-cell">
                                    <i class="fa-solid fa-file-code file-icon"></i>
                                    <strong>@job.FileName</strong>
                                </td>
                                <td>@job.PrinterName</td>
                                <td>@job.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@job.DurationLabel</td>
                                <td class="weight-cell">@job.FilamentWeightGrams g</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<PrintJob> PrintJobs = new();
    private List<Printer> Printers = new();
    private string FilterPrinterId = "";
    private string FilterStatus = "";

    private double TotalWeight => Math.Round(PrintJobs.Sum(j => j.FilamentWeightGrams) / 1000.0, 2);
    private int SuccessRate => PrintJobs.Count > 0
        ? (int)((double)PrintJobs.Count(j => j.Status == PrintStatus.Success) / PrintJobs.Count * 100)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Historique des Impressions", "Journal de bord des 30 derniers jours");
        Printers = PrinterService.GetPrinters();
        await LoadJobs();
    }

    private async Task LoadJobs()
    {
        string? printerId = string.IsNullOrEmpty(FilterPrinterId) ? null : FilterPrinterId;
        PrintStatus? status = null;
        if (Enum.TryParse<PrintStatus>(FilterStatus, out var parsed))
            status = parsed;

        PrintJobs = await PrintJobService.GetRecentJobsAsync(30, printerId, status);

        #if DEBUG
        if (PrintJobs.Count == 0 && printerId == null && status == null) LoadMockPrintJobs();
        #endif
    }

    #if DEBUG
    private void LoadMockPrintJobs()
    {
        var printerNames = new Dictionary<string, string>
        {
            { "printer-ratome", "Ratome" }, { "printer-bonnie", "Bonnie" },
            { "printer-hubble", "Hubble" }, { "printer-r2d2", "R2-D2" }
        };
        var files = new[] { "support_phone.3mf", "engrenage_v2.stl", "boitier_arduino.3mf", "figurine_chat.stl", "clip_cable.stl",
                            "pied_laptop.3mf", "cache_prise.stl", "bras_robot.3mf", "pot_plante.stl", "coque_raspberry.3mf" };
        var rng = new Random(42);

        PrintJobs = Enumerable.Range(1, 10).Select(i =>
        {
            var pid = printerNames.Keys.ElementAt(rng.Next(printerNames.Count));
            var st = i <= 7 ? PrintStatus.Success : i == 8 ? PrintStatus.Failed : PrintStatus.Cancelled;
            return new PrintJob
            {
                Id = i,
                FileName = files[i - 1],
                PrinterId = pid,
                Printer = new Printer { Id = pid, Name = printerNames[pid], Model = "Bambu Lab A1 Mini" },
                StartTime = DateTime.UtcNow.AddDays(-rng.Next(1, 28)).AddHours(-rng.Next(1, 12)),
                Duration = TimeSpan.FromMinutes(rng.Next(30, 480)),
                Status = st,
                FilamentWeightGrams = rng.Next(8, 120)
            };
        }).OrderByDescending(j => j.StartTime).ToList();
    }
    #endif
}
