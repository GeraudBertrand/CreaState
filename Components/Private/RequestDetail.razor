@page "/private/requests/{Id:int}"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]


<PageTitle>Demande #@Id - Créalab</PageTitle>

<div class="content-section">
    @if (Request == null)
    {
        <div class="card-clean text-center" style="padding: 3rem;">
            <p style="color: var(--text-muted);">Demande introuvable.</p>
            <button class="btn btn-secondary mt-2" @onclick="GoBack">Retour</button>
        </div>
    }
    else
    {
        <div class="d-flex gap-3 mb-3">
            <button class="btn btn-secondary btn-sm" @onclick="GoBack">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </button>
        </div>

        <div class="row g-3">
            <!-- Détails principaux -->
            <div class="col-md-8">
                <div class="card-clean" style="padding: 1.5rem;">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <h4 style="margin: 0;">@Request.Title</h4>
                        <span class="badge @GetStatusCssClass(Request.Status)">@Request.Status.GetDisplayName()</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <small style="color: var(--text-muted);">Type</small>
                            <div><strong>@Request.Type.GetDisplayName()</strong></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <small style="color: var(--text-muted);">Description</small>
                        <div style="background: var(--bg-body); padding: 1rem; border-radius: 8px; margin-top: 0.25rem;">
                            @Request.Description
                        </div>
                    </div>

                    @if (Request.Status == RequestStatus.Rejected && !string.IsNullOrEmpty(Request.RejectionReason))
                    {
                        <div style="background: #ffe6e6; padding: 1rem; border-radius: 8px; border-left: 4px solid var(--status-error);">
                            <strong><i class="fa-solid fa-circle-xmark"></i> Raison du rejet :</strong>
                            <p style="margin: 0.5rem 0 0;">@Request.RejectionReason</p>
                        </div>
                    }
                </div>

                <!-- Section fichiers -->
                <div class="card-clean mt-3" style="padding: 1.5rem;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h6 style="margin: 0;"><i class="fa-solid fa-paperclip"></i> Fichiers (@Request.Fichiers.Count)</h6>
                        @if (CanEditFiles)
                        {
                            <label class="btn btn-sm btn-outline-primary" style="cursor: pointer; margin: 0;">
                                <i class="fa-solid fa-plus"></i> Ajouter
                                <InputFile OnChange="HandleAddFile" accept=".stl,.3mf,.dxf,.obj" style="display: none;" />
                            </label>
                        }
                    </div>

                    @if (!Request.Fichiers.Any())
                    {
                        <p style="color: var(--text-muted); text-align: center; padding: 1rem;">Aucun fichier joint.</p>
                    }
                    else
                    {
                        <div class="files-list">
                            @foreach (var file in Request.Fichiers.OrderBy(f => f.UploadedAt))
                            {
                                var fileCss = GetFileStatusCss(file.ReviewStatus);
                                var sizeLabel = GetFileSizeLabel(file.FileSize);

                                <div class="file-row">
                                    <div class="file-info">
                                        <i class="fa-solid fa-file-code" style="color: var(--primary-blue);"></i>
                                        <div class="file-details">
                                            <a href="@file.FilePath" target="_blank" class="file-name">@file.FileName</a>
                                            <small>@sizeLabel — @file.UploadedAt.ToString("dd/MM HH:mm")</small>
                                        </div>
                                        <span class="file-status-badge @fileCss">@file.ReviewStatus.GetDisplayName()</span>
                                    </div>

                                    <div class="file-actions">
                                        @if (IsManager)
                                        {
                                            var acceptCss = file.ReviewStatus == FileReviewStatus.Accepted ? "active" : "";
                                            var refuseCss = file.ReviewStatus == FileReviewStatus.Refused ? "active" : "";
                                            var modifyCss = file.ReviewStatus == FileReviewStatus.NeedsModification ? "active" : "";

                                            <button class="btn-file-action accept @acceptCss"
                                                    title="Valider ce fichier" @onclick="() => ReviewFile(file.Id, FileReviewStatus.Accepted)">
                                                <i class="fa-solid fa-check"></i> Accepter
                                            </button>
                                            <button class="btn-file-action refuse @refuseCss"
                                                    title="Refuser ce fichier" @onclick="() => ReviewFile(file.Id, FileReviewStatus.Refused)">
                                                <i class="fa-solid fa-xmark"></i> Refuser
                                            </button>
                                            <button class="btn-file-action modify @modifyCss"
                                                    title="Demander une modification" @onclick="() => OpenCommentModal(file.Id)">
                                                <i class="fa-solid fa-pen"></i> À modifier
                                            </button>
                                        }

                                        @if (CanEditFiles && (file.ReviewStatus == FileReviewStatus.Refused || file.ReviewStatus == FileReviewStatus.NeedsModification || file.ReviewStatus == FileReviewStatus.Pending))
                                        {
                                            <label class="btn-file-action replace" title="Envoyer une nouvelle version" style="cursor: pointer;">
                                                <i class="fa-solid fa-arrows-rotate"></i> Remplacer
                                                <InputFile OnChange="(e) => HandleReplaceFile(e, file.Id)" accept=".stl,.3mf,.dxf,.obj" style="display: none;" />
                                            </label>
                                            <button class="btn-file-action delete" title="Retirer ce fichier" @onclick="() => DeleteFile(file.Id)">
                                                <i class="fa-solid fa-trash"></i> Supprimer
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (IsManager && Request.Fichiers.Any(f => f.ReviewStatus != FileReviewStatus.Pending))
                    {
                        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e1e8ed;">
                            <button class="btn btn-sm btn-primary"
                                    @onclick="SendNotification" disabled="@IsSendingNotification">
                                <i class="fa-solid fa-bell"></i>
                                Prévenir le demandeur
                            </button>
                            @if (!string.IsNullOrEmpty(NotificationMessage))
                            {
                                <span style="margin-left: 8px; font-size: 0.82rem; color: #117a65;">@NotificationMessage</span>
                            }
                        </div>
                    }
                </div>

                <!-- Section Discussion -->
                @if (IsManager || IsOwner)
                {
                    <div class="card-clean mt-3 comments-section" style="padding: 1.5rem;">
                        <h6 style="margin: 0 0 1rem;"><i class="fa-solid fa-comments"></i> Discussion</h6>

                        @if (Request.Commentaires.Any())
                        {
                            <div class="comments-list">
                                @foreach (var comment in Request.Commentaires.OrderBy(c => c.Date))
                                {
                                    var auteurInitials = comment.Auteur != null
                                        ? $"{comment.Auteur.FirstName[0]}{comment.Auteur.LastName[0]}".ToUpper()
                                        : "??";
                                    var auteurName = comment.Auteur != null
                                        ? $"{comment.Auteur.FirstName} {comment.Auteur.LastName}"
                                        : "Inconnu";

                                    var avatarBg = comment.AuteurId == Request.DemandeurId ? "var(--primary-blue)" : "var(--accent-magenta)";

                                    <div class="comment-item">
                                        <div class="comment-avatar" style="background: @avatarBg">
                                            @auteurInitials
                                        </div>
                                        <div class="comment-body">
                                            <div class="comment-meta">
                                                <strong>@auteurName</strong>
                                                <span class="comment-date">@comment.Date.ToString("dd/MM/yyyy HH:mm")</span>
                                            </div>
                                            <p class="comment-text">@comment.Contenu</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="color: var(--text-muted); text-align: center; padding: 0.5rem;">Aucun message pour l'instant.</p>
                        }

                        <div class="comment-form">
                            <textarea class="form-input" @bind="NewCommentText" rows="2" placeholder="Écrire un message..."></textarea>
                            <button class="btn btn-sm btn-primary" @onclick="SendComment" disabled="@string.IsNullOrWhiteSpace(NewCommentText)">
                                <i class="fa-solid fa-paper-plane"></i> Envoyer
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar info -->
            <div class="col-md-4">
                <div class="card-clean" style="padding: 1.5rem;">
                    <h6>Informations</h6>

                    <div class="mb-2">
                        <small style="color: var(--text-muted);">Demandeur</small>
                        <div><strong>@(Request.Demandeur != null ? $"{Request.Demandeur.FirstName} {Request.Demandeur.LastName}" : "—")</strong></div>
                    </div>

                    <div class="mb-2">
                        <small style="color: var(--text-muted);">Créée le</small>
                        <div>@Request.CreatedAt.ToString("dd/MM/yyyy à HH:mm")</div>
                    </div>

                    @if (Request.UpdatedAt.HasValue)
                    {
                        <div class="mb-2">
                            <small style="color: var(--text-muted);">Mise à jour le</small>
                            <div>@Request.UpdatedAt.Value.ToString("dd/MM/yyyy à HH:mm")</div>
                        </div>
                    }

                    @if (Request.Assigne != null)
                    {
                        <div class="mb-2">
                            <small style="color: var(--text-muted);">Assignée à</small>
                            <div><strong>@($"{Request.Assigne.FirstName} {Request.Assigne.LastName}")</strong></div>
                        </div>
                    }
                </div>

                @if (IsManager)
                {
                    <div class="card-clean mt-3" style="padding: 1.5rem;">
                        <h6>Actions</h6>

                        @if (Request.Status == RequestStatus.Submitted)
                        {
                            <button class="btn btn-success btn-sm w-100 mb-2" @onclick="Approve">
                                <i class="fa-solid fa-check"></i> Approuver
                            </button>
                            <button class="btn btn-danger btn-sm w-100" @onclick="Reject">
                                <i class="fa-solid fa-xmark"></i> Rejeter
                            </button>
                        }
                        else if (Request.Status == RequestStatus.Approved)
                        {
                            <button class="btn btn-info btn-sm w-100" @onclick="Start">
                                <i class="fa-solid fa-play"></i> Lancer
                            </button>
                        }
                        else if (Request.Status == RequestStatus.InProgress)
                        {
                            <button class="btn btn-success btn-sm w-100" @onclick="Complete">
                                <i class="fa-solid fa-flag-checkered"></i> Terminer
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal commentaire -->
@if (ShowCommentModal)
{
    <div class="modal-overlay" @onclick="() => ShowCommentModal = false">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-icon-circle primary">
                    <i class="fa-solid fa-comment"></i>
                </div>
                <div>
                    <h5>Commentaire</h5>
                    <span class="modal-subtitle">Indiquer la modification demandée</span>
                </div>
                <button class="modal-close" @onclick="() => ShowCommentModal = false">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Commentaire</label>
                    <textarea class="form-input" @bind="CommentText" rows="3" placeholder="Décrivez les modifications à apporter..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-action btn-secondary" @onclick="() => ShowCommentModal = false">Annuler</button>
                <button class="btn-action btn-primary-fill" @onclick="SubmitComment">
                    <i class="fa-solid fa-paper-plane"></i> Envoyer
                </button>
            </div>
        </div>
    </div>
}
