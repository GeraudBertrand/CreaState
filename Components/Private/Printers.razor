@page "/private/printers"
@layout PrivateLayout
@attribute [Authorize(Policy = "ViewPrinters")]

@using CreaState.Services
@inject PageHeaderService HeaderService
@inject PrinterService PrinterService
@implements IDisposable

<PageTitle>Créalab Monitor</PageTitle>

<div class="main-container theme-industrial">

    @if (Imprimantes == null)
    {
        <div class="state-message">
            <div class="spinner"></div>
            <p>Connexion aux imprimantes...</p>
        </div>
    }
    else if (Imprimantes.Count == 0)
    {
        <div class="state-message empty">
            <i class="fa-solid fa-server"></i>
            <h3>Aucune imprimante détectée</h3>
            <p>Le parc est vide ou le serveur MQTT est éteint.</p>
        </div>
    }
    else
    {
        <div class="printer-grid">
            @foreach (var printer in Imprimantes)
            {
                <PrinterCard Printer="@printer" />
            }
        </div>
    }
</div>

@code {
    private List<PrinterRuntimeState>? Imprimantes;

    protected override void OnInitialized()
    {
        HeaderService.SetTitle("État du Parc", "Supervision en temps réel des Bambu Lab");
        Imprimantes = PrinterService.GetPrinterStates();
        PrinterService.OnChange += RefreshUI;
    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PrinterService.OnChange -= RefreshUI;
    }
}
