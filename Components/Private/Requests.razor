@page "/private/requests"
@layout PrivateLayout
@attribute [Authorize(Policy = "ManageRequests")]

@inject PageHeaderService HeaderService
@inject RequestService RequestService
@inject AuthStateProvider AuthState
@inject NavigationManager NavManager

<PageTitle>Demandes - Créalab</PageTitle>

<div class="content-section">
    <!-- Filtres -->
    <div class="card-clean" style="padding: 1rem 1.5rem; margin-bottom: 1.5rem;">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="form-group mb-0">
                <select class="form-control" @bind="FilterStatus" @bind:after="LoadRequestList" style="min-width: 180px;">
                    <option value="">Tous les statuts</option>
                    @foreach (var status in Enum.GetValues<RequestStatus>())
                    {
                        <option value="@status">@status.GetDisplayName()</option>
                    }
                </select>
            </div>
            <div style="margin-left: auto; color: var(--text-muted); font-size: 0.85rem;">
                @RequestList.Count demande(s)
            </div>
        </div>
    </div>

    <!-- Liste des demandes -->
    @if (RequestList.Count == 0)
    {
        <div class="card-clean text-center" style="padding: 3rem;">
            <i class="fa-solid fa-inbox fa-3x" style="color: var(--text-muted); margin-bottom: 1rem;"></i>
            <p style="color: var(--text-muted);">Aucune demande pour le moment.</p>
        </div>
    }
    else
    {
        <div class="card-clean">
            <div class="table-responsive">
                <table class="table" style="margin: 0;">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Statut</th>
                            <th>Type</th>
                            <th>Titre</th>
                            <th>Demandeur</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in RequestList)
                        {
                            var statusCss = GetStatusCssClass(req.Status);

                            <tr>
                                <td><strong>@req.Id</strong></td>
                                <td>
                                    <span class="badge @statusCss">@req.Status.GetDisplayName()</span>
                                </td>
                                <td>@req.Type.GetDisplayName()</td>
                                <td>@req.Title</td>
                                <td>@(req.Demandeur != null ? $"{req.Demandeur.FirstName} {req.Demandeur.LastName}" : "—")</td>
                                <td>@req.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewDetail(req.Id)">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                    @if (IsManager && req.Status == RequestStatus.Submitted)
                                    {
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => ApproveRequest(req.Id)">
                                            <i class="fa-solid fa-check"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowRejectModal(req.Id)">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    }
                                    @if (IsManager && req.Status == RequestStatus.Approved)
                                    {
                                        <button class="btn btn-sm btn-outline-info" @onclick="() => StartRequest(req.Id)">
                                            <i class="fa-solid fa-play"></i>
                                        </button>
                                    }
                                    @if (IsManager && req.Status == RequestStatus.InProgress)
                                    {
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => CompleteRequest(req.Id)">
                                            <i class="fa-solid fa-flag-checkered"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

<CreaState.Components.Dialog.RejectRequestDialog
    Show="ShowReject"
    RequestId="RejectingRequestId"
    OnClose="() => ShowReject = false"
    OnSubmit="HandleReject" />

@code {
    private List<Requete> RequestList = new();
    private string FilterStatus { get; set; } = "";
    private bool IsManager = false;

    private bool ShowReject = false;
    private int RejectingRequestId;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Gestion des Demandes", "Suivi des tickets d'impression et de découpe");

        IsManager = AuthState.HasPermission("manage_requests");

        await LoadRequestList();
    }

    private async Task LoadRequestList()
    {
        RequestStatus? filter = null;
        if (Enum.TryParse<RequestStatus>(FilterStatus, out var parsed))
            filter = parsed;

        var membre = AuthState.CurrentMembre;
        if (IsManager)
        {
            RequestList = await RequestService.GetAllRequestsAsync(filter);
        }
        else if (membre != null)
        {
            RequestList = await RequestService.GetRequestsForUserAsync(membre.Id);
            if (filter.HasValue)
                RequestList = RequestList.Where(r => r.Status == filter.Value).ToList();
        }

        #if DEBUG
        if (RequestList.Count == 0 && !filter.HasValue) LoadMockRequests();
        #endif
    }

    #if DEBUG
    private void LoadMockRequests()
    {
        var mockUser = new Membre { Id = 16, FirstName = "Nathan", LastName = "Simon", MembreRoles = [new MembreRole { RoleId = 2, Role = new Role { Id = 2, DisplayName = "Membre" } }] };
        var mockUser2 = new Membre { Id = 17, FirstName = "Julie", LastName = "Michel", MembreRoles = [new MembreRole { RoleId = 2, Role = new Role { Id = 2, DisplayName = "Membre" } }] };

        RequestList = new List<Requete>
        {
            new() { Id = 1, Type = RequestType.FDM, Title = "Support de téléphone personnalisé", Description = "Impression d'un support ajustable.", Status = RequestStatus.Submitted, DemandeurId = 16, Demandeur = mockUser, CreatedAt = DateTime.UtcNow.AddDays(-2),
                    Fichiers = new List<RequeteFichier> { new() { Id = 1, FileName = "support_v3.stl", FileSize = 245000, ReviewStatus = FileReviewStatus.Pending } } },
            new() { Id = 2, Type = RequestType.FDM, Title = "Boîtier Arduino Nano", Description = "Boîtier de protection pour Arduino Nano.", Status = RequestStatus.Approved, DemandeurId = 17, Demandeur = mockUser2, CreatedAt = DateTime.UtcNow.AddDays(-5),
                    Fichiers = new List<RequeteFichier> { new() { Id = 2, FileName = "boitier_nano.3mf", FileSize = 580000, ReviewStatus = FileReviewStatus.Accepted } } },
            new() { Id = 3, Type = RequestType.Laser, Title = "Gravure plaque signalétique", Description = "Plaque avec logo Créalab pour la porte.", Status = RequestStatus.InProgress, DemandeurId = 16, Demandeur = mockUser, CreatedAt = DateTime.UtcNow.AddDays(-7),
                    Fichiers = new List<RequeteFichier> { new() { Id = 3, FileName = "plaque_logo.dxf", FileSize = 120000, ReviewStatus = FileReviewStatus.Accepted } } },
            new() { Id = 4, Type = RequestType.SLA, Title = "Figurine détaillée", Description = "Impression résine haute résolution.", Status = RequestStatus.Completed, DemandeurId = 17, Demandeur = mockUser2, CreatedAt = DateTime.UtcNow.AddDays(-14),
                    Fichiers = new List<RequeteFichier> { new() { Id = 4, FileName = "figurine.stl", FileSize = 1200000, ReviewStatus = FileReviewStatus.Accepted } } },
            new() { Id = 5, Type = RequestType.FDM, Title = "Pièce trop volumineuse", Description = "Pièce de 50cm, hors gabarit.", Status = RequestStatus.Rejected, DemandeurId = 16, Demandeur = mockUser, CreatedAt = DateTime.UtcNow.AddDays(-3), RejectionReason = "Dimensions trop grandes pour nos imprimantes.",
                    Fichiers = new List<RequeteFichier> { new() { Id = 5, FileName = "grosse_piece.stl", FileSize = 3500000, ReviewStatus = FileReviewStatus.Refused } } },
        };
    }
    #endif

    private static string GetStatusCssClass(RequestStatus s) => s switch
    {
        RequestStatus.Submitted => "badge-info",
        RequestStatus.UnderReview => "badge-warning",
        RequestStatus.Approved => "badge-success",
        RequestStatus.Rejected => "badge-danger",
        RequestStatus.InProgress => "badge-primary",
        RequestStatus.Completed => "badge-success",
        RequestStatus.Cancelled => "badge-secondary",
        _ => ""
    };

    private void ViewDetail(int id) => NavManager.NavigateTo($"/private/requests/{id}");

    private async Task ApproveRequest(int id)
    {
        var membre = AuthState.CurrentMembre;
        await RequestService.UpdateStatusAsync(id, RequestStatus.Approved, membre?.Id);
        await LoadRequestList();
    }

    private void ShowRejectModal(int id)
    {
        RejectingRequestId = id;
        ShowReject = true;
    }

    private async Task HandleReject(string reason)
    {
        var membre = AuthState.CurrentMembre;
        await RequestService.UpdateStatusAsync(RejectingRequestId, RequestStatus.Rejected, membre?.Id, reason);
        ShowReject = false;
        await LoadRequestList();
    }

    private async Task StartRequest(int id)
    {
        await RequestService.UpdateStatusAsync(id, RequestStatus.InProgress);
        await LoadRequestList();
    }

    private async Task CompleteRequest(int id)
    {
        await RequestService.UpdateStatusAsync(id, RequestStatus.Completed);
        await LoadRequestList();
    }
}
