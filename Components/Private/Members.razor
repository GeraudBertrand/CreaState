@page "/private/members"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@inject PageHeaderService HeaderService
@inject MemberService MemberService

<PageTitle>Créalab - Membres</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="filters-bar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" placeholder="Rechercher..."
                   @bind="SearchTerm" @bind:event="oninput" />
        </div>

        <div class="filter-buttons">
            <button class="filter-btn @(FilterType == "All" ? "active" : "")"
                    @onclick='() => SetFilter("All")'>
                Tous
            </button>
            <button class="filter-btn @(FilterType == "Board" ? "active" : "")"
                    @onclick='() => SetFilter("Board")'>
                Bureau
            </button>
        </div>
    </div>
</SectionContent>

<div class="main-container theme-industrial">
    <div class="members-grid">
        @foreach (var member in FilteredMembers)
        {
            <MemberCard member="@member" />
        }
    </div>
</div>


@code {

    private List<Membre> AllMembers = new();
    private string SearchTerm = "";
    private string FilterType = "All";

    protected override async Task OnInitializedAsync()
    {
        AllMembers = await MemberService.GetActiveMembersAsync();

        #if DEBUG
        if (AllMembers.Count <= 1) LoadMockMembers();
        #endif

        HeaderService.SetTitle($"Membres ({AllMembers.Count})", "Annuaire de l'association");
    }

    #if DEBUG
    private void LoadMockMembers()
    {
        AllMembers = new List<Membre>
        {
            new() { Id = 10, FirstName = "Lucas", LastName = "Martin", Email = "lucas.martin@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 10, Role = new Role { Id = 10, DisplayName = "Président" } }], ClassYear = ClassYearEnum.A3, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-18) },
            new() { Id = 11, FirstName = "Emma", LastName = "Bernard", Email = "emma.bernard@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 9, Role = new Role { Id = 9, DisplayName = "Vice-président" } }], ClassYear = ClassYearEnum.A3, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-16) },
            new() { Id = 12, FirstName = "Hugo", LastName = "Petit", Email = "hugo.petit@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 3, Role = new Role { Id = 3, DisplayName = "Resp. Technique" } }], ClassYear = ClassYearEnum.A2, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-12) },
            new() { Id = 13, FirstName = "Sarah", LastName = "Dubois", Email = "sarah.dubois@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 8, Role = new Role { Id = 8, DisplayName = "Trésorier" } }], ClassYear = ClassYearEnum.A3, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-14) },
            new() { Id = 14, FirstName = "Thomas", LastName = "Moreau", Email = "thomas.moreau@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 7, Role = new Role { Id = 7, DisplayName = "Secrétaire" } }], ClassYear = ClassYearEnum.A2, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-10) },
            new() { Id = 15, FirstName = "Camille", LastName = "Laurent", Email = "camille.laurent@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 4, Role = new Role { Id = 4, DisplayName = "Resp. Communication" } }], ClassYear = ClassYearEnum.A2, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-8) },
            new() { Id = 16, FirstName = "Nathan", LastName = "Simon", Email = "nathan.simon@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 2, Role = new Role { Id = 2, DisplayName = "Membre" } }], ClassYear = ClassYearEnum.A1, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-3) },
            new() { Id = 17, FirstName = "Julie", LastName = "Michel", Email = "julie.michel@edu.devinci.fr", MembreRoles = [new MembreRole { RoleId = 2, Role = new Role { Id = 2, DisplayName = "Membre" } }], ClassYear = ClassYearEnum.A1, IsActive = true, JoinDate = DateTime.UtcNow.AddMonths(-2) },
        };
    }
    #endif

    private List<Membre> FilteredMembers
    {
        get
        {
            var query = AllMembers.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                var fullName = (Membre m) => $"{m.FirstName} {m.LastName}";
                var roleLabel = (Membre m) => string.Join(", ", m.MembreRoles.Select(mr => mr.Role?.DisplayName ?? ""));
                query = query.Where(m =>
                    fullName(m).Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                    roleLabel(m).Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                );
            }

            switch (FilterType)
            {
                case "Board":
                    query = query.Where(m => m.MembreRoles.Any(mr => mr.Role?.Name != "Eleve"));
                    break;
            }

            return query.ToList();
        }
    }

    private void SetFilter(string type)
    {
        FilterType = type;
    }
}
