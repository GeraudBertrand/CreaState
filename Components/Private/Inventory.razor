@page "/private/inventory"
@layout PrivateLayout
@attribute [Authorize(Policy = "ManageInventory")]

@inject PageHeaderService HeaderService
@inject InventoryService InventoryService
@inject AuthStateProvider AuthState

<PageTitle>Inventaire - Créalab</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="stats-summary">
        <div class="stat-box">
            <span class="stat-value">@Items.Count</span>
            <span class="stat-label">Articles</span>
        </div>
        <div class="stat-box @(LowStockItems.Any() ? "stat-warning" : "")">
            <span class="stat-value">@LowStockItems.Count</span>
            <span class="stat-label">Stock bas</span>
        </div>
    </div>
</SectionContent>

<div class="main-container">

    <!-- Filtres et actions -->
    <div class="filter-bar">
        <div class="filter-group">
            <input class="form-input" @bind="FilterType" @bind:event="oninput" @bind:after="LoadItems" placeholder="Filtrer par type..." />
        </div>
        @if (IsManager)
        {
            <button class="btn-action btn-primary-fill" @onclick="OpenAddModal">
                <i class="fa-solid fa-plus"></i> Ajouter un article
            </button>
        }
    </div>

    <!-- Alerte stock bas -->
    @if (LowStockItems.Any())
    {
        <div class="alert-low-stock">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
                <strong>Stock bas</strong>
                <div class="low-stock-badges">
                    @foreach (var item in LowStockItems)
                    {
                        <span class="badge-low">@item.Type @(!string.IsNullOrEmpty(item.CouleurNom) ? item.CouleurNom : "") — @item.Quantite</span>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Tableau inventaire -->
    @if (Items.Count == 0)
    {
        <div class="empty-state">
            <i class="fa-solid fa-boxes-stacked"></i>
            <p>Aucun article en stock.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <div class="table-scroll">
                <table class="inventory-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Couleur</th>
                            <th>Stock</th>
                            <th>Seuil</th>
                            <th>Niveau</th>
                            @if (IsManager)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Items)
                        {
                            var isLow = item.Quantite <= item.Seuil;
                            var pct = item.Seuil > 0 ? Math.Min(100, (int)((double)item.Quantite / item.Seuil * 100)) : 100;

                            <tr class="table-row @(isLow ? "row-low" : "")">
                                <td><strong>@item.Type</strong></td>
                                <td>
                                    <div class="material-cell">
                                        @if (!string.IsNullOrEmpty(item.CouleurHex))
                                        {
                                            <span class="color-dot" style="background: @item.CouleurHex;"></span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.CouleurNom))
                                        {
                                            <span>@item.CouleurNom</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="stock-value @(isLow ? "stock-danger" : "")">@item.Quantite</span>
                                </td>
                                <td>@item.Seuil</td>
                                <td>
                                    <div class="progress-bar-container">
                                        <div class="progress-bar-bg">
                                            <div class="progress-bar-fill @(isLow ? "fill-danger" : pct < 50 ? "fill-warning" : "fill-ok")"
                                                 style="width: @(pct)%;"></div>
                                        </div>
                                        <span class="progress-label @(isLow ? "stock-danger" : "")">@pct%</span>
                                    </div>
                                </td>
                                @if (IsManager)
                                {
                                    <td>
                                        @if (EditingItemId == item.Id)
                                        {
                                            <div class="inline-edit">
                                                <input type="number" class="form-input form-input-sm" @bind="EditQuantity" />
                                                <button class="btn-icon-sm success" @onclick="() => SaveQuantity(item.Id)"><i class="fa-solid fa-check"></i></button>
                                                <button class="btn-icon-sm muted" @onclick="() => EditingItemId = 0"><i class="fa-solid fa-xmark"></i></button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button class="btn-icon-action" @onclick="() => StartEdit(item)" title="Modifier la quantité">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<CreaState.Components.Dialog.AddInventoryItemDialog
    Show="ShowAddForm"
    OnClose="() => ShowAddForm = false"
    OnSubmit="HandleAddItem" />

@code {
    private List<Consommable> Items = new();
    private List<Consommable> LowStockItems = new();
    private string FilterType = "";
    private bool IsManager = false;
    private bool ShowAddForm = false;

    private int EditingItemId = 0;
    private int EditQuantity = 0;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Inventaire", "Stock de matériaux et consommables");

        IsManager = AuthState.HasPermission("manage_inventory");

        await LoadItems();
    }

    private async Task LoadItems()
    {
        string? type = string.IsNullOrWhiteSpace(FilterType) ? null : FilterType;

        Items = await InventoryService.GetAllItemsAsync(type);
        LowStockItems = await InventoryService.GetLowStockItemsAsync();

        #if DEBUG
        if (Items.Count == 0 && type == null) LoadMockItems();
        #endif
    }

    #if DEBUG
    private void LoadMockItems()
    {
        Items = new List<Consommable>
        {
            new() { Id = 1, Type = "PLA", CouleurNom = "Noir", CouleurHex = "#1a1a1a", Quantite = 620, Seuil = 200 },
            new() { Id = 2, Type = "PLA", CouleurNom = "Blanc", CouleurHex = "#ffffff", Quantite = 150, Seuil = 200 },
            new() { Id = 3, Type = "PETG", CouleurNom = "Bleu", CouleurHex = "#2980b9", Quantite = 830, Seuil = 200 },
            new() { Id = 4, Type = "ABS", CouleurNom = "Rouge", CouleurHex = "#e74c3c", Quantite = 90, Seuil = 150 },
            new() { Id = 5, Type = "Résine UV", CouleurNom = "Grise", CouleurHex = "#95a5a6", Quantite = 350, Seuil = 100 },
        };
        LowStockItems = Items.Where(i => i.Quantite <= i.Seuil).ToList();
    }
    #endif

    private void OpenAddModal()
    {
        ShowAddForm = true;
    }

    private void StartEdit(Consommable item)
    {
        EditingItemId = item.Id;
        EditQuantity = item.Quantite;
    }

    private async Task SaveQuantity(int itemId)
    {
        await InventoryService.UpdateQuantityAsync(itemId, EditQuantity);
        EditingItemId = 0;
        await LoadItems();
    }

    private async Task HandleAddItem(Consommable item)
    {
        await InventoryService.AddItemAsync(item);
        ShowAddForm = false;
        await LoadItems();
    }
}
