@page "/private/maintenance"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@inject PageHeaderService HeaderService
@inject MaintenanceService MaintenanceService
@inject PrinterService PrinterService
@inject AuthStateProvider AuthState

<PageTitle>Maintenance - Créalab</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="stats-summary">
        <div class="stat-box">
            <span class="stat-value">@AllRecords.Count</span>
            <span class="stat-label">Interventions</span>
        </div>
    </div>
</SectionContent>

<div class="main-container">

    <!-- Encadrés par imprimante -->
    <div class="printer-grid">
        @foreach (var printer in Printers)
        {
            var records = RecordsByPrinter.GetValueOrDefault(printer.Id, new());
            var lastMaintenance = records.FirstOrDefault();

            <div class="printer-maintenance-card">
                <div class="printer-card-stripe stripe-ok"></div>
                <div class="printer-card-body">
                    <div class="printer-card-header">
                        <div class="printer-card-icon icon-ok">
                            <i class="fa-solid fa-print"></i>
                        </div>
                        <div class="printer-card-info">
                            <strong>@printer.Name</strong>
                            <span class="printer-model">@printer.Model</span>
                        </div>
                        <span class="status-badge status-ok">
                            <i class="fa-solid fa-check"></i> OK
                        </span>
                    </div>

                    <div class="printer-card-details">
                        @if (lastMaintenance != null)
                        {
                            <div class="detail-row">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span>Dernière : <strong>@lastMaintenance.Date.ToString("dd/MM/yyyy")</strong></span>
                            </div>
                            <div class="detail-row">
                                <i class="fa-solid fa-tag"></i>
                                <span>@lastMaintenance.Type.GetDisplayName()</span>
                            </div>
                        }
                        else
                        {
                            <div class="detail-row muted">
                                <i class="fa-solid fa-clock"></i>
                                <span>Aucune maintenance enregistrée</span>
                            </div>
                        }
                    </div>

                    <div class="printer-card-actions">
                        <button class="btn-action btn-danger-outline" @onclick="() => StartBreakdownReport(printer.Id, printer.Name)">
                            <i class="fa-solid fa-triangle-exclamation"></i> Signaler panne
                        </button>
                        @if (IsManager)
                        {
                            <button class="btn-action btn-primary-outline" @onclick="() => OpenAddModal(printer.Id)">
                                <i class="fa-solid fa-plus"></i> Maintenance
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Historique complet -->
    <div class="table-container">
        <div class="table-header">
            <h6><i class="fa-solid fa-clock-rotate-left"></i> Historique de maintenance</h6>
            @if (IsManager)
            {
                <button class="btn-action btn-primary-fill" @onclick="() => OpenAddModal(null)">
                    <i class="fa-solid fa-plus"></i> Ajouter
                </button>
            }
        </div>

        @if (AllRecords.Count == 0)
        {
            <div class="empty-state">
                <i class="fa-solid fa-wrench"></i>
                <p>Aucun enregistrement de maintenance.</p>
            </div>
        }
        else
        {
            <div class="table-scroll">
                <table class="maintenance-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Machine</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Par</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in AllRecords)
                        {
                            <tr class="table-row">
                                <td>@record.Date.ToString("dd/MM/yyyy")</td>
                                <td><strong>@(record.Printer?.Name ?? "—")</strong></td>
                                <td><span class="type-label">@record.Type.GetDisplayName()</span></td>
                                <td class="desc-cell">@record.Description</td>
                                <td>
                                    <div class="user-cell">
                                        @if (record.Worker != null)
                                        {
                                            <div class="mini-avatar">@($"{record.Worker.FirstName[0]}{record.Worker.LastName[0]}".ToUpper())</div>
                                            @($"{record.Worker.FirstName} {record.Worker.LastName}")
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<CreaState.Components.Dialog.ReportBreakdownDialog
    Show="ShowBreakdownForm"
    PrinterName="@BreakdownPrinterName"
    OnClose="() => ShowBreakdownForm = false"
    OnSubmit="HandleBreakdownSubmit" />

<CreaState.Components.Dialog.AddMaintenanceDialog
    Show="ShowAddForm"
    Printers="Printers"
    PreselectedPrinterId="@AddModalPrinterId"
    OnClose="() => ShowAddForm = false"
    OnSubmit="HandleAddMaintenanceSubmit" />

@code {
    private List<Printer> Printers = new();
    private List<Models.Maintenance> AllRecords = new();
    private Dictionary<int, List<Models.Maintenance>> RecordsByPrinter = new();
    private bool IsManager = false;

    // Signalement panne
    private bool ShowBreakdownForm = false;
    private int BreakdownPrinterId;
    private string BreakdownPrinterName = "";

    // Ajout maintenance
    private bool ShowAddForm = false;
    private int? AddModalPrinterId;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Maintenance", "Suivi et signalement des pannes machines");

        IsManager = AuthState.HasPermission("manage_maintenance");

        Printers = PrinterService.GetPrinters();
        await LoadData();
    }

    private async Task LoadData()
    {
        AllRecords = await MaintenanceService.GetAllRecordsAsync();

        #if DEBUG
        if (AllRecords.Count == 0) LoadMockRecords();
        #endif

        RecordsByPrinter = AllRecords
            .GroupBy(r => r.PrinterId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(r => r.Date).ToList());
    }

    #if DEBUG
    private void LoadMockRecords()
    {
        var mockMember = new Membre { Id = 10, FirstName = "Hugo", LastName = "Petit", MembreRoles = [new MembreRole { RoleId = 3, Role = new Role { Id = 3, DisplayName = "Resp. Technique" } }] };

        AllRecords = new List<Models.Maintenance>
        {
            new() { Id = 1, PrinterId = 1, Printer = new Printer { Id = 1, Name = "Ratome", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Calibration, Description = "Calibration XY complète après déplacement de la machine.", Date = DateTime.UtcNow.AddDays(-5), WorkerId = 10, Worker = mockMember },
            new() { Id = 2, PrinterId = 2, Printer = new Printer { Id = 2, Name = "Bonnie", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Autre, Description = "Buse bouchée, extrusion irrégulière.", Date = DateTime.UtcNow.AddDays(-3), WorkerId = 10, Worker = mockMember },
            new() { Id = 3, PrinterId = 3, Printer = new Printer { Id = 3, Name = "Hubble", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Reparation, Description = "Courroie axe Y détendue, remplacée.", Date = DateTime.UtcNow.AddDays(-10), WorkerId = 10, Worker = mockMember },
            new() { Id = 4, PrinterId = 4, Printer = new Printer { Id = 4, Name = "R2-D2", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Nettoyage, Description = "Nettoyage plateau et ventilateurs.", Date = DateTime.UtcNow.AddDays(-2), WorkerId = 10, Worker = mockMember },
        };
    }
    #endif

    private void StartBreakdownReport(int printerId, string printerName)
    {
        BreakdownPrinterId = printerId;
        BreakdownPrinterName = printerName;
        ShowBreakdownForm = true;
    }

    private async Task HandleBreakdownSubmit(string description)
    {
        var membre = AuthState.CurrentMembre;
        if (membre == null) return;

        var record = new Models.Maintenance
        {
            PrinterId = BreakdownPrinterId,
            WorkerId = membre.Id,
            Type = MaintenanceType.Reparation,
            Description = description,
            Date = DateTime.UtcNow
        };

        await MaintenanceService.AddRecordAsync(record);
        ShowBreakdownForm = false;
        await LoadData();
    }

    private void OpenAddModal(int? printerId)
    {
        AddModalPrinterId = printerId;
        ShowAddForm = true;
    }

    private async Task HandleAddMaintenanceSubmit(Models.Maintenance record)
    {
        var membre = AuthState.CurrentMembre;
        if (membre == null) return;

        record.WorkerId = membre.Id;
        record.Date = DateTime.UtcNow;

        await MaintenanceService.AddRecordAsync(record);
        ShowAddForm = false;
        await LoadData();
    }
}
