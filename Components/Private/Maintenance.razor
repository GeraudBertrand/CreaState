@page "/private/maintenance"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@inject PageHeaderService HeaderService
@inject MaintenanceService MaintenanceService
@inject PrinterService PrinterService
@inject AuthStateProvider AuthState

<PageTitle>Maintenance - Créalab</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="stats-summary">
        <div class="stat-box">
            <span class="stat-value">@UnresolvedCount</span>
            <span class="stat-label">Pannes actives</span>
        </div>
        <div class="stat-box">
            <span class="stat-value">@AllRecords.Count</span>
            <span class="stat-label">Interventions</span>
        </div>
    </div>
</SectionContent>

<div class="main-container">

    <!-- Encadrés par imprimante -->
    <div class="printer-grid">
        @foreach (var printer in Printers)
        {
            var records = RecordsByPrinter.GetValueOrDefault(printer.Id, new());
            var lastMaintenance = records.Where(r => !r.IsBreakdownReport).FirstOrDefault();
            var unresolvedBreakdowns = records.Where(r => r.IsBreakdownReport && !r.IsResolved).ToList();
            var hasActiveBreakdown = unresolvedBreakdowns.Any();

            <div class="printer-maintenance-card @(hasActiveBreakdown ? "has-breakdown" : "")">
                <div class="printer-card-stripe @(hasActiveBreakdown ? "stripe-error" : "stripe-ok")"></div>
                <div class="printer-card-body">
                    <div class="printer-card-header">
                        <div class="printer-card-icon @(hasActiveBreakdown ? "icon-error" : "icon-ok")">
                            <i class="fa-solid fa-print"></i>
                        </div>
                        <div class="printer-card-info">
                            <strong>@printer.Name</strong>
                            <span class="printer-model">@printer.Model</span>
                        </div>
                        @if (hasActiveBreakdown)
                        {
                            <span class="status-badge status-error">
                                <i class="fa-solid fa-triangle-exclamation"></i> PANNE
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-ok">
                                <i class="fa-solid fa-check"></i> OK
                            </span>
                        }
                    </div>

                    <div class="printer-card-details">
                        @if (lastMaintenance != null)
                        {
                            <div class="detail-row">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span>Dernière : <strong>@lastMaintenance.PerformedAt.ToString("dd/MM/yyyy")</strong></span>
                            </div>
                            <div class="detail-row">
                                <i class="fa-solid fa-tag"></i>
                                <span>@lastMaintenance.Type.GetDisplayName()</span>
                            </div>
                        }
                        else
                        {
                            <div class="detail-row muted">
                                <i class="fa-solid fa-clock"></i>
                                <span>Aucune maintenance enregistrée</span>
                            </div>
                        }
                        @if (hasActiveBreakdown)
                        {
                            <div class="detail-row error">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span>@unresolvedBreakdowns.Count panne(s) non résolue(s)</span>
                            </div>
                        }
                    </div>

                    <div class="printer-card-actions">
                        <button class="btn-action btn-danger-outline" @onclick="() => StartBreakdownReport(printer.Id, printer.Name)">
                            <i class="fa-solid fa-triangle-exclamation"></i> Signaler panne
                        </button>
                        @if (IsManager)
                        {
                            <button class="btn-action btn-primary-outline" @onclick="() => OpenAddModal(printer.Id)">
                                <i class="fa-solid fa-plus"></i> Maintenance
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Maintenance planifiée -->
    @if (UpcomingMaintenance.Any())
    {
        <div class="upcoming-banner">
            <h6><i class="fa-solid fa-calendar-check"></i> Maintenance planifiée (7 prochains jours)</h6>
            @foreach (var record in UpcomingMaintenance)
            {
                <div class="upcoming-row">
                    <strong>@(record.Printer?.Name ?? "—")</strong>
                    <span>@record.Type.GetDisplayName()</span>
                    <span class="upcoming-date">@record.NextScheduledAt?.ToString("dd/MM/yyyy")</span>
                </div>
            }
        </div>
    }

    <!-- Historique complet -->
    <div class="table-container">
        <div class="table-header">
            <h6><i class="fa-solid fa-clock-rotate-left"></i> Historique de maintenance</h6>
            @if (IsManager)
            {
                <button class="btn-action btn-primary-fill" @onclick="() => OpenAddModal(null)">
                    <i class="fa-solid fa-plus"></i> Ajouter
                </button>
            }
        </div>

        @if (AllRecords.Count == 0)
        {
            <div class="empty-state">
                <i class="fa-solid fa-wrench"></i>
                <p>Aucun enregistrement de maintenance.</p>
            </div>
        }
        else
        {
            <div class="table-scroll">
                <table class="maintenance-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Machine</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Par</th>
                            <th>Prochaine</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in AllRecords)
                        {
                            var isUnresolved = record.IsBreakdownReport && !record.IsResolved;

                            <tr class="table-row @(isUnresolved ? "row-breakdown" : "") @(record.IsBreakdownReport && record.IsResolved ? "row-resolved" : "")">
                                <td>@record.PerformedAt.ToString("dd/MM/yyyy")</td>
                                <td><strong>@(record.Printer?.Name ?? "—")</strong></td>
                                <td>
                                    @if (record.IsBreakdownReport)
                                    {
                                        <span class="status-badge @(record.IsResolved ? "status-resolved" : "status-error")">
                                            <i class="fa-solid @(record.IsResolved ? "fa-check-circle" : "fa-triangle-exclamation")"></i>
                                            @(record.IsResolved ? "Résolue" : "Panne")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="type-label">@record.Type.GetDisplayName()</span>
                                    }
                                </td>
                                <td class="desc-cell">@record.Description</td>
                                <td>
                                    <div class="user-cell">
                                        <div class="mini-avatar">@(record.PerformedBy?.Initials ?? "?")</div>
                                        @(record.PerformedBy?.FullName ?? "—")
                                    </div>
                                </td>
                                <td>@(record.NextScheduledAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (isUnresolved && IsManager)
                                    {
                                        <button class="btn-repair" @onclick="() => OpenRepairModal(record)">
                                            <i class="fa-solid fa-wrench"></i> Réparer
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<CreaState.Components.Dialog.ReportBreakdownDialog
    Show="ShowBreakdownForm"
    PrinterName="@BreakdownPrinterName"
    OnClose="() => ShowBreakdownForm = false"
    OnSubmit="HandleBreakdownSubmit" />

<CreaState.Components.Dialog.RepairBreakdownDialog
    Show="ShowRepairModal"
    Record="RepairRecord"
    OnClose="() => ShowRepairModal = false"
    OnSubmit="HandleRepairSubmit" />

<CreaState.Components.Dialog.AddMaintenanceDialog
    Show="ShowAddForm"
    Printers="Printers"
    PreselectedPrinterId="@AddModalPrinterId"
    OnClose="() => ShowAddForm = false"
    OnSubmit="HandleAddMaintenanceSubmit" />

@code {
    private List<Printer> Printers = new();
    private List<MaintenanceRecord> AllRecords = new();
    private List<MaintenanceRecord> UpcomingMaintenance = new();
    private Dictionary<string, List<MaintenanceRecord>> RecordsByPrinter = new();
    private bool IsManager = false;
    private int UnresolvedCount = 0;

    // Signalement panne
    private bool ShowBreakdownForm = false;
    private string BreakdownPrinterId = "";
    private string BreakdownPrinterName = "";

    // Réparation
    private bool ShowRepairModal = false;
    private MaintenanceRecord? RepairRecord;

    // Ajout maintenance
    private bool ShowAddForm = false;
    private string? AddModalPrinterId;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Maintenance", "Suivi et signalement des pannes machines");

        var member = AuthState.CurrentMember;
        IsManager = AuthState.HasPermission("manage_maintenance");

        Printers = PrinterService.GetPrinters();
        await LoadData();
    }

    private async Task LoadData()
    {
        AllRecords = await MaintenanceService.GetAllRecordsAsync();
        UpcomingMaintenance = await MaintenanceService.GetUpcomingMaintenanceAsync();

        #if DEBUG
        if (AllRecords.Count == 0) LoadMockRecords();
        #endif

        UnresolvedCount = AllRecords.Count(r => r.IsBreakdownReport && !r.IsResolved);

        RecordsByPrinter = AllRecords
            .GroupBy(r => r.PrinterId)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    #if DEBUG
    private void LoadMockRecords()
    {
        var mockMember = new Member { Id = 10, FirstName = "Hugo", LastName = "Petit", MemberRoles = [new MemberRole { RoleId = 3, Role = new Role { Id = 3, DisplayName = "Resp. Technique" } }] };

        AllRecords = new List<MaintenanceRecord>
        {
            new() { Id = 1, PrinterId = "printer-ratome", Printer = new Printer { Id = "printer-ratome", Name = "Ratome", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Calibration, Description = "Calibration XY complète après déplacement de la machine.", PerformedAt = DateTime.UtcNow.AddDays(-5), PerformedByMemberId = 10, PerformedBy = mockMember },
            new() { Id = 2, PrinterId = "printer-bonnie", Printer = new Printer { Id = "printer-bonnie", Name = "Bonnie", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Other, Description = "Buse bouchée, extrusion irrégulière.", PerformedAt = DateTime.UtcNow.AddDays(-3), PerformedByMemberId = 10, PerformedBy = mockMember,
                    IsBreakdownReport = true, IsResolved = false },
            new() { Id = 3, PrinterId = "printer-hubble", Printer = new Printer { Id = "printer-hubble", Name = "Hubble", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Repair, Description = "Courroie axe Y détendue, remplacée.", PerformedAt = DateTime.UtcNow.AddDays(-10), PerformedByMemberId = 10, PerformedBy = mockMember,
                    IsBreakdownReport = true, IsResolved = true, ResolvedAt = DateTime.UtcNow.AddDays(-9), ResolvedByMemberId = 10, ResolvedBy = mockMember },
            new() { Id = 4, PrinterId = "printer-r2d2", Printer = new Printer { Id = "printer-r2d2", Name = "R2-D2", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Cleaning, Description = "Nettoyage plateau et ventilateurs.", PerformedAt = DateTime.UtcNow.AddDays(-2), PerformedByMemberId = 10, PerformedBy = mockMember },
            new() { Id = 5, PrinterId = "printer-ratome", Printer = new Printer { Id = "printer-ratome", Name = "Ratome", Model = "Bambu Lab A1 Mini" },
                    Type = MaintenanceType.Scheduled, Description = "Maintenance préventive mensuelle prévue.", PerformedAt = DateTime.UtcNow.AddDays(-1), PerformedByMemberId = 10, PerformedBy = mockMember,
                    NextScheduledAt = DateTime.UtcNow.AddDays(25) },
        };

        UpcomingMaintenance = AllRecords.Where(r => r.NextScheduledAt.HasValue && r.NextScheduledAt > DateTime.UtcNow).ToList();
    }
    #endif

    private void StartBreakdownReport(string printerId, string printerName)
    {
        BreakdownPrinterId = printerId;
        BreakdownPrinterName = printerName;
        ShowBreakdownForm = true;
    }

    private async Task HandleBreakdownSubmit(string description)
    {
        var member = AuthState.CurrentMember;
        if (member == null) return;

        await MaintenanceService.ReportBreakdownAsync(BreakdownPrinterId, member.Id, description);
        ShowBreakdownForm = false;
        await LoadData();
    }

    private void OpenRepairModal(MaintenanceRecord record)
    {
        RepairRecord = record;
        ShowRepairModal = true;
    }

    private async Task HandleRepairSubmit((MaintenanceType Type, string Description) result)
    {
        if (RepairRecord == null) return;

        var member = AuthState.CurrentMember;
        if (member == null) return;

        await MaintenanceService.ResolveBreakdownAsync(RepairRecord.Id, member.Id, result.Description, result.Type);
        ShowRepairModal = false;
        await LoadData();
    }

    private void OpenAddModal(string? printerId)
    {
        AddModalPrinterId = printerId;
        ShowAddForm = true;
    }

    private async Task HandleAddMaintenanceSubmit((MaintenanceRecord Record, DateTime? NextDate) result)
    {
        var member = AuthState.CurrentMember;
        if (member == null) return;

        result.Record.PerformedByMemberId = member.Id;
        result.Record.PerformedAt = DateTime.UtcNow;
        if (result.NextDate.HasValue)
            result.Record.NextScheduledAt = result.NextDate.Value;

        await MaintenanceService.AddRecordAsync(result.Record);
        ShowAddForm = false;
        await LoadData();
    }
}
