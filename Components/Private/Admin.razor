@page "/private/admin"
@layout PrivateLayout
@attribute [Authorize(Policy = "AdminOnly")]

@inject PageHeaderService HeaderService

<PageTitle>Créalab - Administration</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="system-status">
        <span class="status-dot online"></span> Serveur MQTT: <strong>Connecté</strong>
    </div>
</SectionContent>

<div class="main-container theme-industrial">
    <div class="tabs">
        <button class="tab-btn @(ActiveTab == "users" ? "active" : "")"
                @onclick='() => SetTab("users")'>
            <i class="fa-solid fa-users-gear"></i> Utilisateurs
        </button>
        <button class="tab-btn @(ActiveTab == "events" ? "active" : "")"
                @onclick='() => SetTab("events")'>
            <i class="fa-solid fa-calendar-days"></i> Événements
        </button>
        <button class="tab-btn @(ActiveTab == "printers" ? "active" : "")"
                @onclick='() => SetTab("printers")'>
            <i class="fa-solid fa-print"></i> Parc Machines
        </button>
    </div>

    <div class="tab-content">
        @if (ActiveTab == "users")
        {
            <AdminUsers @ref="UsersTab" />
        }
        else if (ActiveTab == "events")
        {
            <AdminEvents />
        }
        else if (ActiveTab == "printers")
        {
            <AdminPrinters />
        }
    </div>
</div>

@code {
    private string ActiveTab = "users";
    private AdminUsers? UsersTab;

    protected override void OnInitialized()
    {
        HeaderService.SetTitle("Administration", "Gestion des utilisateurs et du parc machines");
    }

    private void SetTab(string tab)
    {
        ActiveTab = tab;
    }
}
