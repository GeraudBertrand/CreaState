@page "/private/admin"
@layout PrivateLayout
@attribute [Authorize(Policy = "AdminOnly")]

@inject PageHeaderService HeaderService
@inject MemberService MemberService
@inject RoleService RoleService
@inject AuthStateProvider AuthState

<PageTitle>Créalab - Administration</PageTitle>

<SectionContent SectionName="HeaderActions">
    <div class="system-status">
        <span class="status-dot online"></span> Serveur MQTT: <strong>Connecté</strong>
    </div>
</SectionContent>

<div class="main-container theme-industrial">
    <div class="tabs">
        <button class="tab-btn @(ActiveTab == "printers" ? "active" : "")"
                @onclick='async () => await SetTab("printers")'>
            <i class="fa-solid fa-print"></i> Parc Machines
        </button>
        <button class="tab-btn @(ActiveTab == "users" ? "active" : "")"
                @onclick='async () => await SetTab("users")'>
            <i class="fa-solid fa-users-gear"></i> Utilisateurs
        </button>
    </div>

    <div class="tab-content">
        @if (ActiveTab == "printers")
        {
            <div class="section-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-network-wired"></i> Configuration Réseau Bambu Lab</h3>
                    <button class="btn btn-sm btn-primary" @onclick="AddNewPrinter">
                        <i class="fa-solid fa-plus"></i> Ajouter
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Modèle</th>
                                <th>IP Locale</th>
                                <th>Access Code</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Printers)
                            {
                                <tr>
                                    <td><input class="form-input" @bind="p.Name" /></td>
                                    <td>
                                        <select class="form-select" @bind="p.Model">
                                            <option value="A1">A1</option>
                                            <option value="A1 Mini">A1 Mini</option>
                                            <option value="X1C">X1 Carbon</option>
                                            <option value="P1S">P1S</option>
                                        </select>
                                    </td>
                                    <td><input class="form-input code-font" @bind="p.IpAddress" placeholder="192.168.1.x" /></td>
                                    <td>
                                        <div class="password-input">
                                            <input type="text" class="form-input code-font" @bind="p.AccessCode" placeholder="Code écran" />
                                        </div>
                                    </td>
                                    <td>
                                        <button class="btn-icon danger" title="Supprimer" @onclick="() => RemovePrinter(p)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                        <button class="btn-icon success" title="Tester Connexion">
                                            <i class="fa-solid fa-wifi"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer-info">
                    <i class="fa-solid fa-circle-info"></i>
                    N'oubliez pas de fixer les IP dans le routeur DHCP du Fablab pour éviter les déconnexions.
                </div>
            </div>
        }

        @if (ActiveTab == "users")
        {
            <div class="section-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-users-gear"></i> Gestion des accès</h3>
                    <span style="font-size: 0.8rem; color: var(--text-muted);">@AllMembers.Count membre(s)</span>
                </div>

                @if (!string.IsNullOrEmpty(UserSuccessMessage))
                {
                    <div style="padding: 0.75rem 1.5rem; background: #e8f8f5; color: #117a65; font-size: 0.85rem; border-bottom: 1px solid #a3e4d7;">
                        <i class="fa-solid fa-check-circle"></i> @UserSuccessMessage
                    </div>
                }

                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Membre</th>
                                <th>Email</th>
                                <th>Année</th>
                                <th>Rôle</th>
                                <th>Inscrit le</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in AllMembers)
                            {
                                var currentMembre = AuthState.CurrentMembre;
                                var isSelf = currentMembre != null && m.Id == currentMembre.Id;
                                var fullName = $"{m.FirstName} {m.LastName}";
                                var initials = $"{m.FirstName[0]}{m.LastName[0]}".ToUpper();
                                var isBoardMember = m.MembreRoles.Any(mr => mr.Role?.Name != "Eleve");
                                var avatarColor = isBoardMember ? "var(--accent-magenta)" : "var(--primary-blue)";

                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <div style="width: 28px; height: 28px; border-radius: 50%; background: @avatarColor; color: white; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 700;">
                                                @initials
                                            </div>
                                            <strong>@fullName</strong>
                                        </div>
                                    </td>
                                    <td style="font-size: 0.82rem; color: var(--text-muted);">@m.Email</td>
                                    <td>@m.ClassYear.GetDisplayName()</td>
                                    <td>
                                        <select class="form-select" style="min-width: 160px; font-size: 0.85rem;"
                                                value="@(m.MembreRoles.FirstOrDefault()?.RoleId ?? 0)"
                                                disabled="@isSelf"
                                                @onchange="(e) => OnRoleChanged(m, e)">
                                            @foreach (var role in AllRoles)
                                            {
                                                <option value="@role.Id">@role.DisplayName</option>
                                            }
                                        </select>
                                    </td>
                                    <td style="font-size: 0.82rem;">@m.JoinDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (!isSelf && PendingRoleChanges.ContainsKey(m.Id))
                                        {
                                            <button class="btn btn-sm btn-primary" @onclick="() => SaveRoleChange(m.Id)">
                                                <i class="fa-solid fa-check"></i> Sauver
                                            </button>
                                        }
                                        @if (isSelf)
                                        {
                                            <span style="font-size: 0.75rem; color: var(--text-muted);"><i class="fa-solid fa-lock"></i> Vous</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (SelectedRoleForPreview != null)
                {
                    <div style="padding: 1rem 1.5rem; border-top: 1px solid var(--border-light); background: #fcfcfc;">
                        <h6 style="margin: 0 0 0.5rem 0; font-size: 0.85rem;">
                            Permissions de <strong>@SelectedRoleForPreview.DisplayName</strong>
                        </h6>
                        <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                            @foreach (var rp in SelectedRoleForPreview.RolePermissions)
                            {
                                <span style="padding: 3px 8px; border-radius: 12px; font-size: 0.72rem; font-weight: 600; background: #e0f7fa; color: var(--primary-blue);">
                                    @rp.Permission.DisplayName
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

@code {
    private string ActiveTab = "printers";

    private List<Printer> Printers = new();

    // Gestion des utilisateurs
    private List<Membre> AllMembers = new();
    private List<Role> AllRoles = new();
    private Dictionary<int, int> PendingRoleChanges = new();
    private Role? SelectedRoleForPreview;
    private string? UserSuccessMessage;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Administration", "Configuration du parc et communication");
        LoadMockPrinters();
        AllMembers = await MemberService.GetAllMembersAsync();
        AllRoles = await RoleService.GetAllRolesAsync();
    }

    private async Task SetTab(string tab)
    {
        ActiveTab = tab;
        UserSuccessMessage = null;
        if (tab == "users")
        {
            AllMembers = await MemberService.GetAllMembersAsync();
        }
    }

    private void OnRoleChanged(Membre member, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var roleId))
        {
            var currentRoleId = member.MembreRoles.FirstOrDefault()?.RoleId ?? 0;
            if (roleId != currentRoleId)
                PendingRoleChanges[member.Id] = roleId;
            else
                PendingRoleChanges.Remove(member.Id);

            SelectedRoleForPreview = AllRoles.FirstOrDefault(r => r.Id == roleId);
        }
    }

    private async Task SaveRoleChange(int memberId)
    {
        if (!PendingRoleChanges.TryGetValue(memberId, out var newRoleId)) return;

        var success = await MemberService.UpdateMemberRolesAsync(memberId, [newRoleId]);
        if (success)
        {
            var member = AllMembers.FirstOrDefault(m => m.Id == memberId);
            var role = AllRoles.FirstOrDefault(r => r.Id == newRoleId);
            UserSuccessMessage = $"Rôle de {member?.FirstName} {member?.LastName} changé en {role?.DisplayName}";
            PendingRoleChanges.Remove(memberId);
            AllMembers = await MemberService.GetAllMembersAsync();
        }
    }

    #region Printers
        private void AddNewPrinter()
        {
            Printers.Add(new Printer { Name = "Nouvelle Imprimante", IpAddress = "0.0.0.0" });
        }

        private void RemovePrinter(Printer p)
        {
            Printers.Remove(p);
        }

        private void LoadMockPrinters()
        {
            Printers = new List<Printer>
            {
                new Printer { Id = 1, Name = "Bambu A1 - 01", Model = "A1", IpAddress = "192.168.1.50", AccessCode = "12345678" },
                new Printer { Id = 2, Name = "Bambu A1 - 02", Model = "A1", IpAddress = "192.168.1.51", AccessCode = "87654321" },
                new Printer { Id = 3, Name = "La X1 Carbon", Model = "X1C", IpAddress = "192.168.1.60", AccessCode = "ABCD1234" },
                new Printer { Id = 4, Name = "Bambu A1 Mini", Model = "A1 Mini", IpAddress = "192.168.1.52", AccessCode = "MINI0001" },
            };
        }
    #endregion
}
