@page "/private"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@using Microsoft.EntityFrameworkCore
@inject PageHeaderService HeaderService
@inject CreaState.Data.AppDbContext Db
@inject PrinterService PrinterService
@inject InventoryService InventoryService
@inject MaintenanceService MaintenanceService

<PageTitle>Créalab - Dashboard</PageTitle>

<div class="main-container theme-industrial">
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-icon kpi-blue"><i class="fa-solid fa-users"></i></div>
            <div class="kpi-content">
                <h3>@MemberCount</h3>
                <p>Membres actifs</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-magenta"><i class="fa-solid fa-print"></i></div>
            <div class="kpi-content">
                <h3>@ActivePrinterCount/@TotalPrinterCount</h3>
                <p>Imprimantes actives</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-orange"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="kpi-content">
                <h3>@BreakdownCount</h3>
                <p>Incident(s) signalé(s)</p>
            </div>
        </div>
    </div>

    <div class="dashboard-layout">
        <div class="col-left">

            @if(latestAnnouncement != null)
            {
                <AnnouncementWidget announcement="@latestAnnouncement" />
            }

            <!-- Alertes stock bas -->
            @if (LowStockItems.Any())
            {
                <div class="widget-card" style="border-left: 4px solid var(--accent-orange);">
                    <div class="widget-title">
                        <span><i class="fa-solid fa-boxes-stacked"></i> Stock bas</span>
                        <a href="private/inventory" style="font-size: 0.8rem; color: var(--primary-blue);">Voir inventaire</a>
                    </div>
                    @foreach (var item in LowStockItems.Take(5))
                    {
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.85rem;">
                            <span>@item.Name</span>
                            <span class="@item.StockCssClass" style="font-weight: 600;">@item.QuantityRemaining @item.Unit</span>
                        </div>
                    }
                </div>
            }

            <div class="widget-card">
                <div class="widget-title">
                    <span><i class="fa-solid fa-graduation-cap"></i> Formations à venir</span>
                    <a href="#" style="font-size: 0.8rem; color: var(--primary-blue);">Voir tout</a>
                </div>

                @if(FormationsList != null && FormationsList.Count != 0){
                    @foreach (var formation in FormationsList)
                    {
                        <FormationWidget Formation="@formation" />
                    }
                }
                else
                {
                    <div class="state-message empty">
                        <h3>Aucune formation planifiée</h3>
                        <p>Laissez nous le temps de préparer un sandwich.</p>
                    </div>
                }


            </div>
        </div>

        <div class="col-right">
            @if(NextEvent != null)
            {
                <EventWidget Event="@NextEvent" />
            }

            <!-- Demandes en attente -->
            @if (PendingRequestCount > 0)
            {
                <div class="widget-card">
                    <div class="widget-title">
                        <span><i class="fa-solid fa-ticket"></i> Demandes</span>
                        <a href="private/requests" style="font-size: 0.8rem; color: var(--primary-blue);">Gérer</a>
                    </div>
                    <div style="text-align: center; padding: 1rem;">
                        <div style="font-size: 2rem; font-weight: 700; color: var(--primary-blue);">@PendingRequestCount</div>
                        <p style="color: var(--text-muted); margin: 0;">demande(s) en attente</p>
                    </div>
                </div>
            }

            <div class="widget-card">
                <div class="widget-title">
                    <span><i class="fa-solid fa-screwdriver-wrench"></i> Matériel</span>
                    <a href="private/maintenance" style="font-size: 0.8rem; color: var(--primary-blue);">Maintenance</a>
                </div>
                <ul style="list-style: none; padding: 0;">
                    @foreach (var printer in PrinterList)
                    {
                        var hasBreakdown = BreakdownPrinterIds.Contains(printer.Id);
                        <li style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.9rem;">
                            <span>
                                <i class="fa-solid @(hasBreakdown ? "fa-triangle-exclamation" : "fa-check")"
                                   style="color: @(hasBreakdown ? "var(--status-error)" : "var(--status-success)");"></i>
                                @printer.Name
                            </span>
                            <span style="font-weight: bold; color: @(hasBreakdown ? "var(--status-error)" : "var(--status-success)");">
                                @(hasBreakdown ? "En panne" : "OK")
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

</div>
@code {
    // KPIs
    private int MemberCount;
    private int ActivePrinterCount;
    private int TotalPrinterCount;
    private int BreakdownCount;
    private int PendingRequestCount;

    // Data lists
    private List<Formation>? FormationsList;
    private List<Announcement>? AllAnnouncements;
    private List<Event>? Events;
    private List<InventoryItem> LowStockItems = new();
    private List<Printer> PrinterList = new();
    private HashSet<string> BreakdownPrinterIds = new();

    private Announcement? latestAnnouncement;
    private Event? NextEvent;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Bienvenue au Créalab", "Résumé des activités et informations importantes");

        // KPIs depuis la BDD
        MemberCount = await Db.Members.CountAsync(m => m.IsActive);
        PendingRequestCount = await Db.Requests.CountAsync(r => r.Status == RequestStatus.Submitted || r.Status == RequestStatus.UnderReview);

        // Imprimantes
        PrinterList = PrinterService.GetPrinters();
        TotalPrinterCount = PrinterList.Count;
        ActivePrinterCount = PrinterList.Count(p => p.Status == PrinterStatus.Printing || p.Status == PrinterStatus.Idle);

        // Pannes
        var breakdowns = await MaintenanceService.GetBreakdownReportsAsync();
        BreakdownPrinterIds = breakdowns.Select(b => b.PrinterId).ToHashSet();
        BreakdownCount = BreakdownPrinterIds.Count;

        // Stock bas
        LowStockItems = await InventoryService.GetLowStockItemsAsync();

        // Formations, Annonces, Événements depuis BDD
        FormationsList = await Db.Formations.OrderBy(f => f.Date).Take(4).ToListAsync();
        AllAnnouncements = await Db.Announcements.OrderByDescending(a => a.PublishDate).ToListAsync();
        Events = await Db.Events.OrderBy(e => e.Date).ToListAsync();

        #if DEBUG
        // Si pas de données en BDD, charger les mocks
        if (MemberCount <= 1) MemberCount = 12;
        if (PendingRequestCount == 0) PendingRequestCount = 3;
        if (LowStockItems.Count == 0) LoadMockLowStock();
        if (BreakdownCount == 0) { BreakdownPrinterIds = new HashSet<string> { "printer-bonnie" }; BreakdownCount = 1; }
        if (FormationsList.Count == 0) LoadMockFormations();
        if (AllAnnouncements.Count == 0) LoadMockAnnouncements();
        if (Events == null || Events.Count == 0) LoadMockEvents();
        #endif

        GetLastAnnouncement();
        GetNextEvent();
    }

    private void GetLastAnnouncement()
    {
        if(AllAnnouncements != null && AllAnnouncements.Count != 0)
        {
            latestAnnouncement = AllAnnouncements
            .Where(a => a.IsActive)
            .OrderByDescending(a => a.PublishDate)
            .OrderByDescending(a => a.Severity)
            .FirstOrDefault();
        }
    }

    private void GetNextEvent()
    {
        if(Events != null && Events.Count != 0)
        {
            NextEvent = Events
            .Where(e => e.IsUpcoming)
            .OrderBy(e => e.Date)
            .FirstOrDefault();
        }
    }

    // Fallback mock data
    private void LoadMockLowStock()
    {
        LowStockItems = new List<InventoryItem>
        {
            new() { Id = 2, Name = "PLA Blanc 1kg", Category = InventoryCategory.Filament, QuantityRemaining = 150, InitialQuantity = 1000, Unit = "g", LowStockThreshold = 200 },
            new() { Id = 4, Name = "ABS Rouge 750g", Category = InventoryCategory.Filament, QuantityRemaining = 90, InitialQuantity = 750, Unit = "g", LowStockThreshold = 150 },
        };
    }

    private void LoadMockFormations()
    {
        FormationsList = new List<Formation>
        {
            new() { Id = 1, Title = "Initiation Impression 3D (FDM)", Description = "Apprenez les bases du tranchage et lancez votre première impression.", Instructor = "Resp. Technique", Date = DateOnly.FromDateTime(DateTime.Now.AddDays(7)), StartTime = new TimeOnly(14, 00), Duration = TimeSpan.FromHours(2) },
            new() { Id = 2, Title = "Sécurité Découpeuse Laser", Description = "Formation obligatoire pour utiliser la Trotec en autonomie.", Instructor = "Sarah", Date = DateOnly.FromDateTime(DateTime.Now.AddDays(14)), StartTime = new TimeOnly(10, 00), Duration = TimeSpan.FromHours(2) },
        };
    }

    private void LoadMockAnnouncements()
    {
        AllAnnouncements = new List<Announcement>
        {
            new() { Id = 1, Title = "Bienvenue sur CreaState !", Message = "La plateforme de gestion du Créalab est en ligne.", Severity = AnnouncementSeverity.Info, PublishDate = DateTime.Now, DisplayDuration = TimeSpan.FromDays(30) }
        };
    }

    private void LoadMockEvents()
    {
        Events = new List<Event>
        {
            new() { Id = 1, Title = "Prochaine réunion Créalab", Description = "Ordre du jour à définir.", Date = DateTime.Now.AddDays(7), IconClass = "fa-calendar-day", Location = "Fablab" }
        };
    }
}
