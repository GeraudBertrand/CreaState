@page "/private"
@layout PrivateLayout
@attribute [Authorize(Policy = "PrivateAccess")]

@using Microsoft.EntityFrameworkCore
@inject PageHeaderService HeaderService
@inject CreaState.Data.AppDbContext Db
@inject PrinterService PrinterService
@inject InventoryService InventoryService
@inject MaintenanceService MaintenanceService

<PageTitle>Créalab - Dashboard</PageTitle>

<div class="main-container theme-industrial">
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-icon kpi-blue"><i class="fa-solid fa-users"></i></div>
            <div class="kpi-content">
                <h3>@MemberCount</h3>
                <p>Membres actifs</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-magenta"><i class="fa-solid fa-print"></i></div>
            <div class="kpi-content">
                <h3>@ActivePrinterCount/@TotalPrinterCount</h3>
                <p>Imprimantes actives</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-orange"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="kpi-content">
                <h3>@LowStockCount</h3>
                <p>Stock bas</p>
            </div>
        </div>
    </div>

    <div class="dashboard-layout">
        <div class="col-left">

            <!-- Alertes stock bas -->
            @if (LowStockItems.Any())
            {
                <div class="widget-card" style="border-left: 4px solid var(--accent-orange);">
                    <div class="widget-title">
                        <span><i class="fa-solid fa-boxes-stacked"></i> Stock bas</span>
                        <a href="private/inventory" style="font-size: 0.8rem; color: var(--primary-blue);">Voir inventaire</a>
                    </div>
                    @foreach (var item in LowStockItems.Take(5))
                    {
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.85rem;">
                            <span>@item.Type @(!string.IsNullOrEmpty(item.CouleurNom) ? item.CouleurNom : "")</span>
                            <span style="font-weight: 600; color: var(--status-error);">@item.Quantite</span>
                        </div>
                    }
                </div>
            }

            <div class="widget-card">
                <div class="widget-title">
                    <span><i class="fa-solid fa-graduation-cap"></i> Formations à venir</span>
                    <a href="#" style="font-size: 0.8rem; color: var(--primary-blue);">Voir tout</a>
                </div>

                @if(FormationsList != null && FormationsList.Count != 0){
                    @foreach (var formation in FormationsList)
                    {
                        <FormationWidget Formation="@formation" />
                    }
                }
                else
                {
                    <div class="state-message empty">
                        <h3>Aucune formation planifiée</h3>
                        <p>Laissez nous le temps de préparer un sandwich.</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-right">
            @if(NextEvent != null)
            {
                <EventWidget Event="@NextEvent" />
            }

            <!-- Demandes en attente -->
            @if (PendingRequestCount > 0)
            {
                <div class="widget-card">
                    <div class="widget-title">
                        <span><i class="fa-solid fa-ticket"></i> Demandes</span>
                        <a href="private/requests" style="font-size: 0.8rem; color: var(--primary-blue);">Gérer</a>
                    </div>
                    <div style="text-align: center; padding: 1rem;">
                        <div style="font-size: 2rem; font-weight: 700; color: var(--primary-blue);">@PendingRequestCount</div>
                        <p style="color: var(--text-muted); margin: 0;">demande(s) en attente</p>
                    </div>
                </div>
            }

            <div class="widget-card">
                <div class="widget-title">
                    <span><i class="fa-solid fa-screwdriver-wrench"></i> Matériel</span>
                    <a href="private/maintenance" style="font-size: 0.8rem; color: var(--primary-blue);">Maintenance</a>
                </div>
                <ul style="list-style: none; padding: 0;">
                    @foreach (var printer in PrinterList)
                    {
                        <li style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.9rem;">
                            <span>
                                <i class="fa-solid fa-check" style="color: var(--status-success);"></i>
                                @printer.Name
                            </span>
                            <span style="font-weight: bold; color: var(--status-success);">OK</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

</div>
@code {
    // KPIs
    private int MemberCount;
    private int ActivePrinterCount;
    private int TotalPrinterCount;
    private int LowStockCount;
    private int PendingRequestCount;

    // Data lists
    private List<Formation>? FormationsList;
    private List<Evenement>? Events;
    private List<Consommable> LowStockItems = new();
    private List<Printer> PrinterList = new();

    private Evenement? NextEvent;

    protected override async Task OnInitializedAsync()
    {
        HeaderService.SetTitle("Bienvenue au Créalab", "Résumé des activités et informations importantes");

        // KPIs depuis la BDD
        MemberCount = await Db.Membres.CountAsync(m => m.IsActive);
        PendingRequestCount = await Db.Requetes.CountAsync(r => r.Status == RequestStatus.Submitted || r.Status == RequestStatus.UnderReview);

        // Imprimantes
        PrinterList = PrinterService.GetPrinters();
        TotalPrinterCount = PrinterList.Count;
        ActivePrinterCount = PrinterList.Count; // All are considered active from config

        // Stock bas
        LowStockItems = await InventoryService.GetLowStockItemsAsync();
        LowStockCount = LowStockItems.Count;

        // Formations, Événements depuis BDD
        FormationsList = await Db.Formations.OrderBy(f => f.Date).Take(4).ToListAsync();
        Events = await Db.Evenements.OrderBy(e => e.Date).ToListAsync();

        #if DEBUG
        if (MemberCount <= 1) MemberCount = 12;
        if (PendingRequestCount == 0) PendingRequestCount = 3;
        if (LowStockItems.Count == 0) LoadMockLowStock();
        if (FormationsList.Count == 0) LoadMockFormations();
        if (Events == null || Events.Count == 0) LoadMockEvents();
        #endif

        GetNextEvent();
    }

    private void GetNextEvent()
    {
        if(Events != null && Events.Count != 0)
        {
            NextEvent = Events
            .Where(e => (e.Date.Date - DateTime.Now.Date).Days >= 0)
            .OrderBy(e => e.Date)
            .FirstOrDefault();
        }
    }

    // Fallback mock data
    private void LoadMockLowStock()
    {
        LowStockItems = new List<Consommable>
        {
            new() { Id = 2, Type = "PLA", CouleurNom = "Blanc", CouleurHex = "#ffffff", Quantite = 150, Seuil = 200 },
            new() { Id = 4, Type = "ABS", CouleurNom = "Rouge", CouleurHex = "#e74c3c", Quantite = 90, Seuil = 150 },
        };
        LowStockCount = LowStockItems.Count;
    }

    private void LoadMockFormations()
    {
        FormationsList = new List<Formation>
        {
            new() { Id = 1, Titre = "Initiation Impression 3D (FDM)", Description = "Apprenez les bases du tranchage et lancez votre première impression.", Date = DateOnly.FromDateTime(DateTime.Now.AddDays(7)), StartTime = new TimeOnly(14, 00), Duration = TimeSpan.FromHours(2) },
            new() { Id = 2, Titre = "Sécurité Découpeuse Laser", Description = "Formation obligatoire pour utiliser la Trotec en autonomie.", Date = DateOnly.FromDateTime(DateTime.Now.AddDays(14)), StartTime = new TimeOnly(10, 00), Duration = TimeSpan.FromHours(2) },
        };
    }

    private void LoadMockEvents()
    {
        Events = new List<Evenement>
        {
            new() { Id = 1, Title = "Prochaine réunion Créalab", Description = "Ordre du jour à définir.", Date = DateTime.Now.AddDays(7), Icone = "fa-calendar-day", Location = "Fablab" }
        };
    }
}
