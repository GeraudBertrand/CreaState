@page "/register"
@layout LoginLayout

@inject NavigationManager NavManager

<PageTitle>Inscription - Crealab</PageTitle>

<div class="login-wrapper theme-industrial">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <i class="fa-solid fa-user-plus fa-3x"></i>
            <h2>Inscription Crealab</h2>
            <p>Creez votre compte avec votre email ecole.</p>
        </div>

        <div class="login-form">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-alert">
                    <i class="fa-solid fa-triangle-exclamation"></i> @ErrorMessage
                </div>
            }

            @* Form POST to /account/register *@
            <form method="post" action="/account/register">
                <div class="flex-row d-flex justify-content-around">
                    <div class="form-group">
                        <label for="firstName">Prenom</label>
                        <input type="text" id="firstName" name="firstName" class="form-control" placeholder="Jean" required />
                    </div>

                    <div class="form-group">
                        <label for="lastName">Nom</label>
                        <input type="text" id="lastName" name="lastName" class="form-control" placeholder="Dupont" required />
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email ecole</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="prenom.nom@edu.devinci.fr" required />
                    <small style="color: var(--text-muted); font-size: 0.8rem;">Seuls les emails @@edu.devinci.fr sont acceptes.</small>
                </div>

                <div class="form-group">
                    <label for="classYear">Annee</label>
                    <select id="classYear" name="classYear" class="form-control">
                        @foreach (var year in Enum.GetValues<ClassYearEnum>())
                        {
                            <option value="@((int)year)">@year.GetDisplayName()</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="Min. 6 caracteres" required />
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirmer le mot de passe</label>
                    <input type="password" id="confirmPassword" class="form-control" placeholder="--------" required />
                </div>

                <button type="submit" class="btn-primary">
                    Creer mon compte
                </button>
            </form>

            <button class="btn-secondary" @onclick="GoToLogin">
                Deja inscrit ? Se connecter
            </button>
        </div>
    </div>
</div>

@code {
    private string ErrorMessage { get; set; } = "";

    protected override void OnInitialized()
    {
        var uri = new Uri(NavManager.Uri);
        if (uri.Query.Contains("error="))
        {
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            ErrorMessage = query["error"] ?? "Erreur lors de l'inscription.";
        }
    }

    private void GoToLogin() => NavManager.NavigateTo("/");
}
