@page "/"
@layout LoginLayout

@inject NavigationManager NavManager
@inject AuthService AuthService
@inject AuthStateProvider AuthState

<PageTitle>Connexion - Créalab</PageTitle>

<div class="login-wrapper theme-industrial">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <i class="fa-solid fa-layer-group fa-3x"></i>
            <h2>Créalab ESILV</h2>
            <p>Portail de connexion au Fablab.</p>
        </div>

        <div class="login-form">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-alert">
                    <i class="fa-solid fa-triangle-exclamation"></i> @ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="alert alert-success" style="background: var(--status-success); color: white; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                    <i class="fa-solid fa-check-circle"></i> @SuccessMessage
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" class="form-control" @bind="Email" placeholder="prenom.nom@edu.devinci.fr" />
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" class="form-control" @bind="Password" @onkeyup="HandleKeyUp" placeholder="••••••••" />
            </div>

            <button class="btn-primary" @onclick="AttemptLogin" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i>
                }
                Se connecter
            </button>

            <button class="btn-secondary" @onclick="GoToRegister">
                Créer un compte
            </button>

            <button class="btn-secondary" @onclick="GoToPublic">
                Accès Visiteur (Site Public)
            </button>
        </div>

        <div class="login-footer">
            <p class="help-text">Utilisez votre email @@edu.devinci.fr pour vous connecter.</p>
        </div>
    </div>
</div>

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    private string SuccessMessage { get; set; } = "";
    private bool IsLoading { get; set; } = false;

    protected override void OnInitialized()
    {
        // Vérifier si un message de succès vient de l'inscription
        var uri = new Uri(NavManager.Uri);
        if (uri.Query.Contains("registered=true"))
        {
            SuccessMessage = "Compte créé avec succès ! Connectez-vous.";
        }
    }

    private async Task AttemptLogin()
    {
        ErrorMessage = "";
        SuccessMessage = "";

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        IsLoading = true;
        try
        {
            var member = await AuthService.LoginAsync(Email, Password);
            if (member != null)
            {
                AuthState.Login(member);
                NavManager.NavigateTo("/private");
            }
            else
            {
                ErrorMessage = "Email ou mot de passe incorrect.";
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoToPublic()
    {
        NavManager.NavigateTo("/public");
    }

    private void GoToRegister()
    {
        NavManager.NavigateTo("/register");
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AttemptLogin();
        }
    }
}
