@page "/"
@layout LoginLayout

@inject NavigationManager NavManager

<PageTitle>Connexion - Crealab</PageTitle>

<div class="login-wrapper theme-industrial">
    <div class="login-card animate-fade-in">
        <div class="login-header">
            <i class="fa-solid fa-layer-group fa-3x"></i>
            <h2>Crealab ESILV</h2>
            <p>Portail de connexion au Fablab.</p>
        </div>

        <div class="login-form">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-alert">
                    <i class="fa-solid fa-triangle-exclamation"></i> @ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="alert alert-success" style="background: var(--status-success); color: white; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                    <i class="fa-solid fa-check-circle"></i> @SuccessMessage
                </div>
            }

            @* Form POST to /account/login — sets the auth cookie server-side *@
            <form method="post" action="/account/login">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="prenom.nom@edu.devinci.fr" />
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="--------" />
                </div>

                <button type="submit" class="btn-primary">
                    Se connecter
                </button>
            </form>

            <button id="register_btn" class="btn-secondary w-75" @onclick="GoToRegister">
                Creer un compte
            </button>

            @* <button class="btn-secondary" @onclick="GoToPublic">
                Acces Visiteur (Site Public)
            </button> *@
        </div>

        <div class="login-footer">
            <p class="help-text">Utilisez votre email @@edu.devinci.fr pour vous connecter.</p>
        </div>
    </div>
</div>

@code {
    private string ErrorMessage { get; set; } = "";
    private string SuccessMessage { get; set; } = "";

    protected override void OnInitialized()
    {
        var uri = new Uri(NavManager.Uri);
        var query = uri.Query.ToLowerInvariant();

        if (query.Contains("registered=true"))
            SuccessMessage = "Compte cree ! Verifiez votre email pour confirmer votre compte.";
        else if (query.Contains("emailconfirmed=true"))
            SuccessMessage = "Email confirme ! Vous pouvez maintenant vous connecter.";
        else if (query.Contains("error=invalid"))
            ErrorMessage = "Email ou mot de passe incorrect.";
        else if (query.Contains("error=email_not_confirmed"))
            ErrorMessage = "Veuillez confirmer votre email avant de vous connecter. Verifiez votre boite de reception.";
        else if (query.Contains("error=invalid_token"))
            ErrorMessage = "Le lien de confirmation est invalide ou a expire.";
    }

    private void GoToPublic() => NavManager.NavigateTo("/public");
    private void GoToRegister() => NavManager.NavigateTo("/register");
}
