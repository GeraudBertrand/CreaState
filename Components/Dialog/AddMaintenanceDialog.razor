@using CreaState.Models

@if (Show)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-panel modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-icon-circle primary">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                </div>
                <div>
                    <h5>Enregistrer une maintenance</h5>
                    <span class="modal-subtitle">Ajouter un enregistrement au journal</span>
                </div>
                <button class="modal-close" @onclick="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Machine</label>
                        <select class="form-input" @bind="NewRecord.PrinterId">
                            <option value="">— Sélectionner —</option>
                            @foreach (var p in Printers)
                            {
                                <option value="@p.Id">@p.Name (@p.Model)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Type d'intervention</label>
                        <select class="form-input" @bind="NewRecord.Type">
                            @foreach (var t in Enum.GetValues<MaintenanceType>())
                            {
                                <option value="@t">@t.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Description détaillée</label>
                    <textarea class="form-input" @bind="NewRecord.Description" rows="4" placeholder="Décrivez l'intervention réalisée, les pièces changées, les réglages effectués..."></textarea>
                </div>
                <div class="form-group">
                    <label>Prochaine maintenance prévue <span class="optional">(optionnel)</span></label>
                    <input type="date" class="form-input" @bind="NextScheduledDate" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-action btn-secondary" @onclick="Close">Annuler</button>
                <button class="btn-action btn-primary-fill" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(NewRecord.PrinterId)">
                    <i class="fa-solid fa-plus"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public List<Printer> Printers { get; set; } = new();
    [Parameter] public string? PreselectedPrinterId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<(MaintenanceRecord Record, DateTime? NextDate)> OnSubmit { get; set; }

    private MaintenanceRecord NewRecord = new();
    private DateTime? NextScheduledDate;

    protected override void OnParametersSet()
    {
        if (Show && string.IsNullOrEmpty(NewRecord.PrinterId) && !string.IsNullOrEmpty(PreselectedPrinterId))
        {
            NewRecord = new MaintenanceRecord { PrinterId = PreselectedPrinterId };
            NextScheduledDate = null;
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(NewRecord.PrinterId)) return;
        await OnSubmit.InvokeAsync((NewRecord, NextScheduledDate));
        NewRecord = new();
        NextScheduledDate = null;
    }
}
