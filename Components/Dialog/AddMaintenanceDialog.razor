@using CreaState.Models

@if (Show)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-panel modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-icon-circle primary">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                </div>
                <div>
                    <h5>Enregistrer une maintenance</h5>
                    <span class="modal-subtitle">Ajouter un enregistrement au journal</span>
                </div>
                <button class="modal-close" @onclick="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Machine</label>
                        <select class="form-input" @bind="SelectedPrinterId">
                            <option value="0">— Sélectionner —</option>
                            @foreach (var p in Printers)
                            {
                                <option value="@p.Id">@p.Name (@p.Model)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Type d'intervention</label>
                        <select class="form-input" @bind="SelectedType">
                            @foreach (var t in Enum.GetValues<MaintenanceType>())
                            {
                                <option value="@t">@t.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Description détaillée</label>
                    <textarea class="form-input" @bind="Description" rows="4" placeholder="Décrivez l'intervention réalisée, les pièces changées, les réglages effectués..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-action btn-secondary" @onclick="Close">Annuler</button>
                <button class="btn-action btn-primary-fill" @onclick="Submit" disabled="@(SelectedPrinterId == 0)">
                    <i class="fa-solid fa-plus"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public List<Printer> Printers { get; set; } = new();
    [Parameter] public int? PreselectedPrinterId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Models.Maintenance> OnSubmit { get; set; }

    private int SelectedPrinterId;
    private MaintenanceType SelectedType = MaintenanceType.Nettoyage;
    private string Description = "";

    protected override void OnParametersSet()
    {
        if (Show && SelectedPrinterId == 0 && PreselectedPrinterId.HasValue)
        {
            SelectedPrinterId = PreselectedPrinterId.Value;
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task Submit()
    {
        if (SelectedPrinterId == 0) return;
        var record = new Models.Maintenance
        {
            PrinterId = SelectedPrinterId,
            Type = SelectedType,
            Description = Description,
            Date = DateTime.UtcNow
        };
        await OnSubmit.InvokeAsync(record);
        SelectedPrinterId = 0;
        SelectedType = MaintenanceType.Nettoyage;
        Description = "";
    }
}
