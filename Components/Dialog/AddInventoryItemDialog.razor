@using CreaState.Models

@if (Show)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-panel modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-icon-circle primary">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div>
                    <h5>Nouveau consommable</h5>
                    <span class="modal-subtitle">Ajouter un élément à l'inventaire</span>
                </div>
                <button class="modal-close" @onclick="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Type <span class="required">*</span></label>
                        <input class="form-input" @bind="NewItem.Type" placeholder="Ex: PLA, PETG, Résine..." />
                    </div>
                    <div class="form-group">
                        <label>Couleur (nom)</label>
                        <input class="form-input" @bind="NewItem.CouleurNom" placeholder="Noir, Blanc, Rouge..." />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Couleur (hex)</label>
                        <input type="color" class="form-input" @bind="NewItem.CouleurHex" />
                    </div>
                </div>

                <div class="form-divider"></div>

                <div class="form-row form-row-3">
                    <div class="form-group">
                        <label>Quantité <span class="required">*</span></label>
                        <input type="number" class="form-input" @bind="NewItem.Quantite" min="0" />
                    </div>
                    <div class="form-group">
                        <label>Seuil d'alerte</label>
                        <input type="number" class="form-input" @bind="NewItem.Seuil" min="0" />
                        <span class="form-hint">Notifié quand le stock passe sous ce seuil</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-action btn-secondary" @onclick="Close">Annuler</button>
                <button class="btn-action btn-primary-fill" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(NewItem.Type)">
                    <i class="fa-solid fa-plus"></i> Ajouter à l'inventaire
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Consommable> OnSubmit { get; set; }

    private Consommable NewItem = new() { Seuil = 5 };

    protected override void OnParametersSet()
    {
        if (Show && string.IsNullOrEmpty(NewItem.Type))
        {
            NewItem = new Consommable { Seuil = 5 };
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(NewItem.Type)) return;
        await OnSubmit.InvokeAsync(NewItem);
        NewItem = new Consommable { Seuil = 5 };
    }
}
