<div class="widget-card event-widget">
    <div class="widget-title">
        <span><i class="fa-solid fa-calendar-star"></i> Événement à la une</span>
    </div>

    <div class="event-content">
        <i class="fa-solid @Event.Icone event-main-icon"></i>

        <h4>@Event.Title</h4>
        <p class="event-desc">@Event.Description</p>

        <div class="countdown-badge @BadgeCssClass">
            @CountdownLabel
        </div>

        <div class="event-meta">
            <span><i class="fa-regular fa-calendar"></i> @Event.Date.ToString("dd MMMM")</span>
            <span><i class="fa-solid fa-location-dot"></i> @Event.Location</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public required Evenement Event { get; set; }

    private int DaysRemaining => (Event.Date.Date - DateTime.Now.Date).Days;
    private bool IsUpcoming => DaysRemaining >= 0;
    private string CountdownLabel => DaysRemaining switch
    {
        0 => "Aujourd'hui !",
        1 => "Demain",
        _ => $"J-{DaysRemaining}"
    };
    private string BadgeCssClass => DaysRemaining <= 3 ? "badge-urgent" : "badge-normal";
}
