@* AnnouncementWidget — Announcement model has been removed.
   This component is now a placeholder and should be replaced with a proper notification system. *@

@if (!string.IsNullOrEmpty(Title))
{
    <div class="widget-card announcement @CssClass animate-pop">
        <div class="widget-title">
            <span>
                <i class="fa-solid @IconClass"></i> @Title
            </span>
        </div>
        <div class="announcement-content">
            <p>@Message</p>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "info";
    [Parameter] public string IconClass { get; set; } = "fa-circle-info";
}
