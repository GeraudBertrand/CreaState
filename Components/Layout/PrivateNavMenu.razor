@inject AuthStateProvider AuthState
@inject NavigationManager NavManager

<div class="logo-area">
    <i class="fa-solid fa-layer-group"></i>
    Créalab
</div>

@if (AuthState.CurrentMember != null)
{
    <div class="user-info" style="padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-light);">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary-blue); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600;">
                @AuthState.CurrentMember.Initials
            </div>
            <div>
                <div style="font-weight: 600; font-size: 0.85rem; color: var(--text-main);">@AuthState.CurrentMember.FullName</div>
                <div style="font-size: 0.7rem; color: var(--text-muted);">@AuthState.CurrentMember.RoleLabel</div>
            </div>
        </div>
    </div>
}

<ul class="nav-links" id="private-navmenu">
    <li>
        <NavLink class="nav-item" href="private/" Match="NavLinkMatch.All">
            <i class="fa-solid fa-chart-pie"></i> Dashboard
        </NavLink>
    </li>

    <AuthorizeView Policy="ViewPrinters">
        <li>
            <NavLink class="nav-item" href="private/printers">
                <i class="fa-solid fa-print"></i> Imprimantes
            </NavLink>
        </li>
    </AuthorizeView>

    <AuthorizeView Policy="ManageRequests">
        <li>
            <NavLink class="nav-item" href="private/requests">
                <i class="fa-solid fa-ticket"></i> Demandes
            </NavLink>
        </li>
    </AuthorizeView>

    <li>
        <NavLink class="nav-item" href="private/history">
            <i class="fa-solid fa-clock-rotate-left"></i> Historique
        </NavLink>
    </li>
    <li>
        <NavLink class="nav-item" href="private/members">
            <i class="fa-solid fa-users"></i> Membres
        </NavLink>
    </li>

    <AuthorizeView Policy="ManageInventory">
        <li>
            <NavLink class="nav-item" href="private/inventory">
                <i class="fa-solid fa-boxes-stacked"></i> Inventaire
            </NavLink>
        </li>
    </AuthorizeView>

    <li>
        <NavLink class="nav-item" href="private/maintenance">
            <i class="fa-solid fa-wrench"></i> Maintenance
        </NavLink>
    </li>

    <AuthorizeView Policy="AdminOnly">
        <li>
            <NavLink class="nav-item" href="private/admin">
                <i class="fa-solid fa-gear"></i> Admin
            </NavLink>
        </li>
    </AuthorizeView>
</ul>

<div style="margin-top: auto; padding: 1rem 1.25rem; border-top: 1px solid var(--border-light);">
    <button class="nav-item" style="width: 100%; background: none; border: none; cursor: pointer; text-align: left; padding: 0.6rem 0.75rem; color: var(--text-muted); border-radius: 8px;"
            @onclick="Logout">
        <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
    </button>
</div>

@code {
    private void Logout()
    {
        AuthState.Logout();
        NavManager.NavigateTo("/");
    }
}
