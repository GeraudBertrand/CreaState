@inherits LayoutComponentBase
@inject PageHeaderService HeaderService
@inject AuthStateProvider AuthState
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <PrivateNavMenu />
    </div> 

    <main>
        <header class="header px-4">
            <div class="header-text">
                <h1>@HeaderService.Title</h1>
                <p>@HeaderService.Description</p>
            </div>

            <div class="header-actions">
                <SectionOutlet SectionName="HeaderActions" />
            </div>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>


@code{
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        HeaderService.OnChange += StateHasChanged;

        // Ensure the AuthStateProvider has loaded the current user/membre from DB
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            await AuthState.EnsureLoadedAsync(authState);
        }
    }

    public void Dispose()
    {
        HeaderService.OnChange -= StateHasChanged;
    }
}